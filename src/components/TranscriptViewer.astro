---
// Transcript viewer: timestamped segments, click-to-seek, search within transcript
// Props: segments (JSON string of [{start, end, text}]), videoId (links to VideoPlayer)
interface Props {
  segments?: string | undefined; // JSON string: [{start: number, end: number, text: string}]
  videoId?: string | undefined;
  defaultOpen?: boolean | undefined;
}

const { segments: segmentsJson, videoId, defaultOpen = false } = Astro.props;

interface Segment {
  start: number;
  end: number;
  text: string;
}

let segments: Segment[] = [];
let hasTranscript = false;

if (segmentsJson) {
  try {
    segments = JSON.parse(segmentsJson) as Segment[];
    hasTranscript =
      segments.length > 0 &&
      !(segments.length === 1 && (segments[0]?.text ?? '').startsWith('Transcript pending'));
  } catch {
    // Invalid JSON
  }
}
---

<div
  class="transcript-viewer bg-white rounded-2xl border border-gray-200 overflow-hidden"
  data-video-id={videoId}
>
  <!-- Toggle header -->
  <button
    class="transcript-toggle w-full flex items-center justify-between px-6 py-4 hover:bg-gray-50 transition-colors"
    aria-expanded={defaultOpen ? 'true' : 'false'}
  >
    <div class="flex items-center gap-3">
      <svg class="w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
      </svg>
      <span class="text-sm font-semibold text-gray-700">Transcript</span>
      {hasTranscript && (
        <span class="text-xs text-gray-400">{segments.length} segments</span>
      )}
    </div>
    <svg class="transcript-chevron w-5 h-5 text-gray-400 transition-transform" style={defaultOpen ? 'transform: rotate(180deg)' : ''} fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
    </svg>
  </button>

  <!-- Transcript body -->
  <div class="transcript-body" style={defaultOpen ? '' : 'display: none'}>
    {hasTranscript ? (
      <>
        {/* Search input */}
        <div class="px-6 pb-3">
          <div class="relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
            </svg>
            <input
              type="text"
              class="transcript-search w-full pl-9 pr-4 py-2 text-sm border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#294bf3]/30 focus:border-[#294bf3] placeholder-gray-400"
              placeholder="Search transcript..."
            />
          </div>
        </div>

        {/* Segments list */}
        <div class="transcript-segments max-h-80 overflow-y-auto px-6 pb-4 space-y-1">
          {segments.map((seg, i) => (
            <button
              class="transcript-segment flex items-start gap-3 w-full text-left px-3 py-2 rounded-lg hover:bg-gray-50 transition-colors group/seg"
              data-start={seg.start}
              data-end={seg.end}
              data-index={i}
            >
              <span class="text-xs font-mono text-[#294bf3] tabular-nums flex-shrink-0 mt-0.5 opacity-70 group-hover/seg:opacity-100">
                {Math.floor(seg.start / 60)}:{String(Math.floor(seg.start % 60)).padStart(2, '0')}
              </span>
              <span class="transcript-text text-sm text-gray-600 leading-relaxed">
                {seg.text}
              </span>
            </button>
          ))}
        </div>

        {/* No results message */}
        <div class="transcript-no-results hidden px-6 pb-4">
          <p class="text-sm text-gray-400 text-center py-4">No matching segments found</p>
        </div>
      </>
    ) : (
      <div class="px-6 pb-6">
        <p class="text-sm text-gray-400">
          {segmentsJson ? 'Transcript pending — will be available once the video is processed.' : 'No transcript available for this lesson yet.'}
        </p>
      </div>
    )}
  </div>
</div>

<script is:inline>
(function () {
  document.querySelectorAll('.transcript-viewer').forEach(function (viewer) {
    var toggle = viewer.querySelector('.transcript-toggle');
    var body = viewer.querySelector('.transcript-body');
    var chevron = viewer.querySelector('.transcript-chevron');
    var searchInput = viewer.querySelector('.transcript-search');
    var segmentsContainer = viewer.querySelector('.transcript-segments');
    var noResults = viewer.querySelector('.transcript-no-results');
    var allSegments = viewer.querySelectorAll('.transcript-segment');
    var videoId = viewer.getAttribute('data-video-id');

    // Toggle open/close
    if (toggle && body && chevron) {
      toggle.addEventListener('click', function () {
        var isOpen = body.style.display !== 'none';
        body.style.display = isOpen ? 'none' : '';
        chevron.style.transform = isOpen ? '' : 'rotate(180deg)';
        toggle.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
      });
    }

    // Search within transcript
    if (searchInput && allSegments.length > 0) {
      searchInput.addEventListener('input', function () {
        var query = searchInput.value.trim().toLowerCase();
        var visibleCount = 0;
        allSegments.forEach(function (seg) {
          var text = seg.querySelector('.transcript-text');
          if (!text) return;
          var matches = !query || text.textContent.toLowerCase().indexOf(query) !== -1;
          seg.style.display = matches ? '' : 'none';
          if (matches) visibleCount++;
        });
        if (noResults) {
          noResults.classList.toggle('hidden', visibleCount > 0 || !query);
        }
        if (segmentsContainer) {
          segmentsContainer.classList.toggle('hidden', visibleCount === 0 && !!query);
        }
      });
    }

    // Click-to-seek: find the linked VideoPlayer
    allSegments.forEach(function (seg) {
      seg.addEventListener('click', function () {
        var start = parseFloat(seg.getAttribute('data-start') || '0');
        // Find the video player wrapper
        var playerWrapper = videoId
          ? document.querySelector('.video-player-wrapper[data-video-id="' + videoId + '"]')
          : document.querySelector('.video-player-wrapper');
        if (playerWrapper && typeof playerWrapper.seekTo === 'function') {
          playerWrapper.seekTo(start);
        }
      });
    });

    // Highlight active segment during playback
    if (videoId) {
      var playerWrapper = document.querySelector('.video-player-wrapper[data-video-id="' + videoId + '"]');
      if (!playerWrapper) {
        playerWrapper = document.querySelector('.video-player-wrapper');
      }
      if (playerWrapper) {
        playerWrapper.addEventListener('video-timeupdate', function (e) {
          var currentTime = e.detail.currentTime;
          allSegments.forEach(function (seg) {
            var segStart = parseFloat(seg.getAttribute('data-start') || '0');
            var segEnd = parseFloat(seg.getAttribute('data-end') || '0');
            var isActive = currentTime >= segStart && currentTime < segEnd;
            seg.classList.toggle('bg-[#f0f7ff]', isActive);
            seg.classList.toggle('border-l-2', isActive);
            seg.classList.toggle('border-[#294bf3]', isActive);
          });

          // Auto-scroll to active segment
          var active = viewer.querySelector('.transcript-segment.bg-\\[\\#f0f7ff\\]');
          if (active && segmentsContainer) {
            var containerRect = segmentsContainer.getBoundingClientRect();
            var segRect = active.getBoundingClientRect();
            if (segRect.top < containerRect.top || segRect.bottom > containerRect.bottom) {
              active.scrollIntoView({ block: 'center', behavior: 'smooth' });
            }
          }
        });
      }
    }
  });
})();
</script>
