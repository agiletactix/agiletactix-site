---
// Custom HTML5 video player with branded controls
// Props: src (video URL), poster (thumbnail URL), title, videoId
interface Props {
  src: string;
  poster?: string | undefined;
  title?: string | undefined;
  videoId?: string | undefined;
}

const { src, poster, title, videoId } = Astro.props;
---

<div
  class="video-player-wrapper relative bg-black rounded-2xl overflow-hidden group"
  data-video-id={videoId}
>
  <video
    id={`video-${videoId || 'main'}`}
    class="video-element w-full aspect-video"
    preload="metadata"
    playsinline
    src={src}
    poster={poster}
  >
    <source src={src} type="video/mp4" />
    Your browser does not support the video element.
  </video>

  <!-- Loading spinner -->
  <div class="video-loading absolute inset-0 flex items-center justify-center bg-black/50 hidden">
    <div class="w-12 h-12 border-4 border-white/30 border-t-white rounded-full animate-spin"></div>
  </div>

  <!-- Error state -->
  <div class="video-error absolute inset-0 flex items-center justify-center bg-black/80 hidden">
    <div class="text-center">
      <svg class="w-12 h-12 text-red-400 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
      </svg>
      <p class="text-white/80 text-sm mb-3">Failed to load video</p>
      <button class="video-retry-btn px-4 py-2 bg-[#294bf3] text-white text-sm rounded-lg hover:bg-[#1e3ad4] transition-colors">
        Retry
      </button>
    </div>
  </div>

  <!-- Big play button (center) -->
  <button class="video-big-play absolute inset-0 flex items-center justify-center bg-black/20 transition-opacity group-hover:bg-black/30">
    <div class="w-20 h-20 rounded-full bg-[#294bf3]/90 flex items-center justify-center backdrop-blur-sm transition-transform hover:scale-110">
      <svg class="w-8 h-8 text-white ml-1" fill="currentColor" viewBox="0 0 24 24">
        <path d="M8 5v14l11-7z" />
      </svg>
    </div>
  </button>

  <!-- Custom controls overlay -->
  <div class="video-controls absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 to-transparent px-4 pb-4 pt-12 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
    <!-- Progress bar -->
    <div class="video-progress-container relative w-full h-1.5 bg-white/20 rounded-full cursor-pointer mb-3 group/progress hover:h-2.5 transition-all">
      <div class="video-progress-buffered absolute inset-y-0 left-0 bg-white/30 rounded-full" style="width: 0%"></div>
      <div class="video-progress-bar absolute inset-y-0 left-0 bg-[#294bf3] rounded-full" style="width: 0%">
        <div class="absolute right-0 top-1/2 -translate-y-1/2 w-3.5 h-3.5 bg-white rounded-full shadow opacity-0 group-hover/progress:opacity-100 transition-opacity"></div>
      </div>
    </div>

    <div class="flex items-center justify-between gap-3">
      <div class="flex items-center gap-3">
        <!-- Play/Pause -->
        <button class="video-play-btn text-white hover:text-[#294bf3] transition-colors" aria-label="Play/Pause">
          <svg class="play-icon w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M8 5v14l11-7z" />
          </svg>
          <svg class="pause-icon w-6 h-6 hidden" fill="currentColor" viewBox="0 0 24 24">
            <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z" />
          </svg>
        </button>

        <!-- Volume -->
        <div class="flex items-center gap-1.5 group/vol">
          <button class="video-mute-btn text-white hover:text-[#294bf3] transition-colors" aria-label="Mute">
            <svg class="vol-on w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z" />
            </svg>
            <svg class="vol-off w-5 h-5 hidden" fill="currentColor" viewBox="0 0 24 24">
              <path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z" />
            </svg>
          </button>
          <input
            type="range"
            class="video-volume-slider w-0 group-hover/vol:w-20 transition-all duration-200 accent-[#294bf3] h-1 cursor-pointer"
            min="0"
            max="1"
            step="0.05"
            value="1"
            aria-label="Volume"
          />
        </div>

        <!-- Time display -->
        <span class="video-time text-white/80 text-xs font-mono tabular-nums">
          0:00 / 0:00
        </span>
      </div>

      <div class="flex items-center gap-3">
        <!-- Playback speed -->
        <div class="relative">
          <button class="video-speed-btn text-white/80 hover:text-white text-xs font-semibold px-2 py-1 rounded bg-white/10 hover:bg-white/20 transition-colors" aria-label="Playback speed">
            1x
          </button>
          <div class="video-speed-menu absolute bottom-full right-0 mb-2 bg-gray-900 border border-white/10 rounded-lg py-1 hidden shadow-xl">
            <button data-speed="0.5" class="speed-option block w-full px-4 py-1.5 text-xs text-white/70 hover:text-white hover:bg-white/10 text-left">0.5x</button>
            <button data-speed="0.75" class="speed-option block w-full px-4 py-1.5 text-xs text-white/70 hover:text-white hover:bg-white/10 text-left">0.75x</button>
            <button data-speed="1" class="speed-option block w-full px-4 py-1.5 text-xs text-white font-semibold hover:bg-white/10 text-left">1x</button>
            <button data-speed="1.25" class="speed-option block w-full px-4 py-1.5 text-xs text-white/70 hover:text-white hover:bg-white/10 text-left">1.25x</button>
            <button data-speed="1.5" class="speed-option block w-full px-4 py-1.5 text-xs text-white/70 hover:text-white hover:bg-white/10 text-left">1.5x</button>
            <button data-speed="2" class="speed-option block w-full px-4 py-1.5 text-xs text-white/70 hover:text-white hover:bg-white/10 text-left">2x</button>
          </div>
        </div>

        <!-- Fullscreen -->
        <button class="video-fullscreen-btn text-white hover:text-[#294bf3] transition-colors" aria-label="Fullscreen">
          <svg class="fs-enter w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M7 14H5v5h5v-2H7v-3zm-2-4h2V7h3V5H5v5zm12 7h-3v2h5v-5h-2v3zM14 5v2h3v3h2V5h-5z" />
          </svg>
          <svg class="fs-exit w-5 h-5 hidden" fill="currentColor" viewBox="0 0 24 24">
            <path d="M5 16h3v3h2v-5H5v2zm3-8H5v2h5V5H8v3zm6 11h2v-3h3v-2h-5v5zm2-11V5h-2v5h5V8h-3z" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</div>

{title && (
  <p class="mt-3 text-sm text-gray-500 font-medium">{title}</p>
)}

<script is:inline>
(function () {
  document.querySelectorAll('.video-player-wrapper').forEach(function (wrapper) {
    var video = wrapper.querySelector('.video-element');
    if (!video) return;

    var bigPlay = wrapper.querySelector('.video-big-play');
    var playBtn = wrapper.querySelector('.video-play-btn');
    var playIcon = wrapper.querySelector('.play-icon');
    var pauseIcon = wrapper.querySelector('.pause-icon');
    var muteBtn = wrapper.querySelector('.video-mute-btn');
    var volOn = wrapper.querySelector('.vol-on');
    var volOff = wrapper.querySelector('.vol-off');
    var volumeSlider = wrapper.querySelector('.video-volume-slider');
    var progressContainer = wrapper.querySelector('.video-progress-container');
    var progressBar = wrapper.querySelector('.video-progress-bar');
    var progressBuffered = wrapper.querySelector('.video-progress-buffered');
    var timeDisplay = wrapper.querySelector('.video-time');
    var speedBtn = wrapper.querySelector('.video-speed-btn');
    var speedMenu = wrapper.querySelector('.video-speed-menu');
    var speedOptions = wrapper.querySelectorAll('.speed-option');
    var fsBtn = wrapper.querySelector('.video-fullscreen-btn');
    var fsEnter = wrapper.querySelector('.fs-enter');
    var fsExit = wrapper.querySelector('.fs-exit');
    var loading = wrapper.querySelector('.video-loading');
    var errorEl = wrapper.querySelector('.video-error');
    var retryBtn = wrapper.querySelector('.video-retry-btn');
    var controls = wrapper.querySelector('.video-controls');

    function formatTime(sec) {
      if (isNaN(sec)) return '0:00';
      var m = Math.floor(sec / 60);
      var s = Math.floor(sec % 60);
      return m + ':' + (s < 10 ? '0' : '') + s;
    }

    function togglePlay() {
      if (video.paused) {
        video.play();
      } else {
        video.pause();
      }
    }

    function updatePlayState() {
      if (video.paused) {
        playIcon.classList.remove('hidden');
        pauseIcon.classList.add('hidden');
        bigPlay.classList.remove('hidden');
      } else {
        playIcon.classList.add('hidden');
        pauseIcon.classList.remove('hidden');
        bigPlay.classList.add('hidden');
      }
    }

    // Play/pause
    bigPlay.addEventListener('click', togglePlay);
    playBtn.addEventListener('click', togglePlay);
    video.addEventListener('click', togglePlay);
    video.addEventListener('play', updatePlayState);
    video.addEventListener('pause', updatePlayState);

    // Time update
    video.addEventListener('timeupdate', function () {
      if (video.duration) {
        var pct = (video.currentTime / video.duration) * 100;
        progressBar.style.width = pct + '%';
        timeDisplay.textContent = formatTime(video.currentTime) + ' / ' + formatTime(video.duration);
      }
      // Dispatch custom event for transcript sync
      wrapper.dispatchEvent(new CustomEvent('video-timeupdate', { detail: { currentTime: video.currentTime } }));
    });

    // Buffered progress
    video.addEventListener('progress', function () {
      if (video.buffered.length > 0 && video.duration) {
        var bufferedEnd = video.buffered.end(video.buffered.length - 1);
        progressBuffered.style.width = (bufferedEnd / video.duration) * 100 + '%';
      }
    });

    // Progress bar click/seek
    progressContainer.addEventListener('click', function (e) {
      var rect = progressContainer.getBoundingClientRect();
      var pct = (e.clientX - rect.left) / rect.width;
      if (video.duration) {
        video.currentTime = pct * video.duration;
      }
    });

    // Volume
    muteBtn.addEventListener('click', function () {
      video.muted = !video.muted;
      volOn.classList.toggle('hidden', video.muted);
      volOff.classList.toggle('hidden', !video.muted);
      volumeSlider.value = video.muted ? 0 : video.volume;
    });

    volumeSlider.addEventListener('input', function () {
      video.volume = parseFloat(volumeSlider.value);
      video.muted = video.volume === 0;
      volOn.classList.toggle('hidden', video.muted);
      volOff.classList.toggle('hidden', !video.muted);
    });

    // Speed
    speedBtn.addEventListener('click', function (e) {
      e.stopPropagation();
      speedMenu.classList.toggle('hidden');
    });

    speedOptions.forEach(function (opt) {
      opt.addEventListener('click', function () {
        var speed = parseFloat(opt.getAttribute('data-speed'));
        video.playbackRate = speed;
        speedBtn.textContent = speed + 'x';
        speedMenu.classList.add('hidden');
      });
    });

    // Close speed menu on outside click
    document.addEventListener('click', function () {
      speedMenu.classList.add('hidden');
    });

    // Fullscreen
    fsBtn.addEventListener('click', function () {
      if (!document.fullscreenElement) {
        wrapper.requestFullscreen().catch(function () {});
      } else {
        document.exitFullscreen();
      }
    });

    wrapper.addEventListener('fullscreenchange', function () {
      var isFs = document.fullscreenElement === wrapper;
      fsEnter.classList.toggle('hidden', isFs);
      fsExit.classList.toggle('hidden', !isFs);
    });

    // Loading state
    video.addEventListener('waiting', function () {
      loading.classList.remove('hidden');
    });
    video.addEventListener('canplay', function () {
      loading.classList.add('hidden');
    });

    // Error state
    video.addEventListener('error', function () {
      loading.classList.add('hidden');
      errorEl.classList.remove('hidden');
      bigPlay.classList.add('hidden');
    });

    retryBtn.addEventListener('click', function () {
      errorEl.classList.add('hidden');
      video.load();
    });

    // Show controls when playing (always visible on hover via CSS)
    video.addEventListener('play', function () {
      controls.style.opacity = '1';
      setTimeout(function () {
        if (!video.paused) controls.style.opacity = '';
      }, 2000);
    });

    // Keyboard shortcuts
    wrapper.setAttribute('tabindex', '0');
    wrapper.addEventListener('keydown', function (e) {
      switch (e.key) {
        case ' ':
        case 'k':
          e.preventDefault();
          togglePlay();
          break;
        case 'f':
          e.preventDefault();
          if (!document.fullscreenElement) {
            wrapper.requestFullscreen().catch(function () {});
          } else {
            document.exitFullscreen();
          }
          break;
        case 'ArrowLeft':
          e.preventDefault();
          video.currentTime = Math.max(0, video.currentTime - 10);
          break;
        case 'ArrowRight':
          e.preventDefault();
          video.currentTime = Math.min(video.duration || 0, video.currentTime + 10);
          break;
        case 'ArrowUp':
          e.preventDefault();
          video.volume = Math.min(1, video.volume + 0.1);
          volumeSlider.value = video.volume;
          break;
        case 'ArrowDown':
          e.preventDefault();
          video.volume = Math.max(0, video.volume - 0.1);
          volumeSlider.value = video.volume;
          break;
        case 'm':
          e.preventDefault();
          video.muted = !video.muted;
          volOn.classList.toggle('hidden', video.muted);
          volOff.classList.toggle('hidden', !video.muted);
          volumeSlider.value = video.muted ? 0 : video.volume;
          break;
      }
    });

    // Expose seek method for transcript click-to-seek
    wrapper.seekTo = function (seconds) {
      video.currentTime = seconds;
      if (video.paused) video.play();
    };
  });
})();
</script>
