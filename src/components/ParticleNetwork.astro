---
// Particle Network Animation Component
// Sparse-left → dense-right gradient visualizing the transformation narrative
---

<canvas id="particle-canvas" class="absolute inset-0 w-full h-full"></canvas>

<script>
  const canvas = document.getElementById('particle-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (ctx) {
    const particleCount = 80;
    const particleSpeed = 0.25;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const connectionDistance = 210 * dpr;

    interface Particle {
      x: number;
      y: number;
      vx: number;
      vy: number;
      radius: number;
    }

    let particles: Particle[] = [];
    let animationId: number;

    function resizeCanvas() {
      const container = canvas.parentElement;
      if (!container) return;
      const w = container.offsetWidth;
      const h = container.offsetHeight;
      canvas.width  = Math.max(1, Math.round(w * dpr));
      canvas.height = Math.max(1, Math.round(h * dpr));
      canvas.style.width  = w + 'px';
      canvas.style.height = h + 'px';
    }

    function initParticles() {
      const W = canvas.width, H = canvas.height;
      const focusX = 0.85 * W;
      const focusY = 0.55 * H;
      const R = Math.max(W, H) * 0.7;

      particles = [];
      for (let i = 0; i < particleCount; i++) {
        const angle = Math.random() * Math.PI * 2;
        const dist  = Math.pow(Math.random(), 0.7) * R;
        const jitter = R * 0.28;
        const vAngle = Math.random() * Math.PI * 2;

        particles.push({
          x:  focusX + Math.cos(angle) * dist + (Math.random() - 0.5) * jitter,
          y:  focusY + Math.sin(angle) * dist + (Math.random() - 0.5) * jitter,
          vx: Math.cos(vAngle) * particleSpeed,
          vy: Math.sin(vAngle) * particleSpeed,
          radius: (Math.random() * 2.2 + 0.8) * dpr,
        });
      }
    }

    function drawParticle(p: Particle) {
      if (!ctx) return;
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(96, 165, 250, 0.65)';
      ctx.fill();

      const grad = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.radius * 5);
      grad.addColorStop(0, 'rgba(96, 165, 250, 0.25)');
      grad.addColorStop(1, 'rgba(96, 165, 250, 0)');
      ctx.fillStyle = grad;
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.radius * 5, 0, Math.PI * 2);
      ctx.fill();
    }

    function drawConnection(p1: Particle, p2: Particle, distance: number) {
      if (!ctx) return;
      const alpha = (1 - distance / connectionDistance) * 0.22;
      ctx.beginPath();
      ctx.moveTo(p1.x, p1.y);
      ctx.lineTo(p2.x, p2.y);
      ctx.strokeStyle = `rgba(96, 165, 250, ${alpha})`;
      ctx.lineWidth = 1;
      ctx.stroke();
    }

    function updateParticle(p: Particle) {
      const pad = 40;

      const angle = Math.atan2(p.vy, p.vx) + (Math.random() - 0.5) * 0.09;
      const speed = Math.hypot(p.vx, p.vy);
      p.vx = Math.cos(angle) * speed;
      p.vy = Math.sin(angle) * speed;

      p.x += p.vx;
      p.y += p.vy;

      if (p.x < pad)                     { p.x = pad;                     p.vx = Math.abs(p.vx); }
      else if (p.x > canvas.width - pad) { p.x = canvas.width - pad;      p.vx = -Math.abs(p.vx); }
      if (p.y < pad)                     { p.y = pad;                     p.vy = Math.abs(p.vy); }
      else if (p.y > canvas.height - pad){ p.y = canvas.height - pad;     p.vy = -Math.abs(p.vy); }
    }

    function animate() {
      if (!ctx) return;
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      for (let i = 0; i < particles.length; i++) {
        const particleI = particles[i]!;
        updateParticle(particleI);
        drawParticle(particleI);

        for (let j = i + 1; j < particles.length; j++) {
          const particleJ = particles[j]!;
          const dx = particleI.x - particleJ.x;
          const dy = particleI.y - particleJ.y;
          const distance = Math.sqrt(dx * dx + dy * dy);

          if (distance < connectionDistance) {
            drawConnection(particleI, particleJ, distance);
          }
        }
      }

      animationId = requestAnimationFrame(animate);
    }

    function handleResize() {
      resizeCanvas();
      initParticles();
    }

    resizeCanvas();
    initParticles();

    if (reduced) {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      for (let i = 0; i < particles.length; i++) {
        const p = particles[i]!;
        drawParticle(p);
        for (let j = i + 1; j < particles.length; j++) {
          const q = particles[j]!;
          const dx = p.x - q.x;
          const dy = p.y - q.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < connectionDistance) drawConnection(p, q, dist);
        }
      }
    } else {
      animate();
    }

    window.addEventListener('resize', handleResize);

    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(animationId);
      window.removeEventListener('resize', handleResize);
    });
  }
</script>
