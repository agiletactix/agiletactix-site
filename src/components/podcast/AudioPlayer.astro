---
interface Props {
  audioUrl: string;
  title: string;
  episodeNumber?: number | undefined;
  duration: string;
}

const { audioUrl, title, episodeNumber, duration } = Astro.props;
const label = episodeNumber ? `Episode ${episodeNumber}` : 'Trailer';
---

<div class="bg-gray-900 rounded-xl p-6 shadow-lg">
  <div class="flex items-center justify-between mb-4">
    <div>
      <span class="text-xs font-semibold uppercase tracking-wider text-primary-400">{label}</span>
      <h3 class="text-white font-bold text-lg mt-1">{title}</h3>
    </div>
    <span class="text-sm text-gray-400 whitespace-nowrap ml-4">{duration}</span>
  </div>
  <audio
    controls
    preload="metadata"
    class="w-full h-10 [&::-webkit-media-controls-panel]:bg-gray-800 [&::-webkit-media-controls-current-time-display]:text-gray-300 [&::-webkit-media-controls-time-remaining-display]:text-gray-300"
  >
    <source src={audioUrl} type="audio/mpeg" />
    Your browser does not support the audio element.
  </audio>
</div>
