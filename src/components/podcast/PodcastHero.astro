---
const appleUrl = '#'; // TODO: Replace with Apple Podcasts URL after submission
const spotifyUrl = '#'; // TODO: Replace with Spotify URL after submission
const rssUrl = '/podcast.xml';
---

<section class="bg-[#0a1628] relative overflow-hidden">
  <!-- Constellation pattern (matching blog style) -->
  <div class="absolute inset-0 pointer-events-none" style="mask-image: linear-gradient(to bottom, transparent 0%, rgba(0,0,0,0.2) 30%, rgba(0,0,0,0.5) 70%, rgba(0,0,0,0.8) 100%); -webkit-mask-image: linear-gradient(to bottom, transparent 0%, rgba(0,0,0,0.2) 30%, rgba(0,0,0,0.5) 70%, rgba(0,0,0,0.8) 100%);">
    <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
      <defs>
        <filter id="podcast-glow" x="-50%" y="-50%" width="200%" height="200%">
          <feGaussianBlur stdDeviation="2" result="blur"/>
          <feMerge>
            <feMergeNode in="blur"/>
            <feMergeNode in="SourceGraphic"/>
          </feMerge>
        </filter>
      </defs>
      <g stroke="rgba(41, 75, 243, 0.12)" stroke-width="0.5" fill="none">
        <line x1="5%" y1="15%" x2="12%" y2="25%" />
        <line x1="12%" y1="25%" x2="8%" y2="40%" />
        <line x1="82%" y1="10%" x2="90%" y2="20%" />
        <line x1="90%" y1="20%" x2="95%" y2="35%" />
      </g>
      <g stroke="rgba(41, 75, 243, 0.25)" stroke-width="1" fill="none">
        <line x1="8%" y1="20%" x2="18%" y2="30%" />
        <line x1="18%" y1="30%" x2="25%" y2="22%" />
        <line x1="75%" y1="15%" x2="85%" y2="25%" />
        <line x1="85%" y1="25%" x2="80%" y2="40%" />
      </g>
      <g fill="rgba(41, 75, 243, 0.3)">
        <circle cx="8%" cy="20%" r="2" />
        <circle cx="18%" cy="30%" r="2.5" />
        <circle cx="25%" cy="22%" r="2" />
        <circle cx="75%" cy="15%" r="2" />
        <circle cx="85%" cy="25%" r="2.5" />
        <circle cx="80%" cy="40%" r="2" />
      </g>
      <g fill="rgba(41, 75, 243, 0.5)" filter="url(#podcast-glow)">
        <circle cx="12%" cy="50%" r="3" />
        <circle cx="92%" cy="45%" r="3.5" />
      </g>
    </svg>
  </div>

  <div class="relative z-10 section-container py-20 sm:py-28 text-center">
    <span class="inline-block bg-primary-600/20 border border-primary-500/30 text-primary-300 text-xs font-bold uppercase tracking-widest px-4 py-1.5 rounded-full mb-6">
      Podcast
    </span>
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white tracking-tight mb-4">
      Career Optional
    </h1>
    <p class="text-xl sm:text-2xl text-gray-300 max-w-2xl mx-auto mb-8">
      The skills that make employment optional.
    </p>
    <p class="text-gray-400 max-w-xl mx-auto mb-10">
      Story-driven episodes exploring agile methodology, AI automation, and career resilience. Hosted by Danny Liu.
    </p>

    <!-- Subscribe Buttons -->
    <div class="flex flex-wrap items-center justify-center gap-4">
      <a href={appleUrl} class="inline-flex items-center bg-white/10 hover:bg-white/20 text-white font-semibold text-sm px-5 py-3 rounded-lg transition-colors duration-200">
        <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
        Apple Podcasts
      </a>
      <a href={spotifyUrl} class="inline-flex items-center bg-white/10 hover:bg-white/20 text-white font-semibold text-sm px-5 py-3 rounded-lg transition-colors duration-200">
        <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
        Spotify
      </a>
      <a href={rssUrl} class="inline-flex items-center bg-white/10 hover:bg-white/20 text-white font-semibold text-sm px-5 py-3 rounded-lg transition-colors duration-200">
        <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/></svg>
        RSS Feed
      </a>
    </div>
  </div>
</section>
