---
interface Props {
  title: string;
  episodeNumber?: number | undefined;
  description: string;
  pubDate: Date;
  duration: string;
  slug: string;
  episodeType: string;
}

const { title, episodeNumber, description, pubDate, duration, slug, episodeType } = Astro.props;
const label = episodeNumber ? `Episode ${episodeNumber}` : episodeType === 'trailer' ? 'Trailer' : 'Bonus';
const formattedDate = new Date(pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<a href={`/podcast/${slug}/`} class="block group">
  <article class="bg-white rounded-xl border border-gray-200 p-6 transition-all duration-200 hover:shadow-lg hover:border-primary-300 hover:-translate-y-0.5">
    <div class="flex items-start justify-between mb-3">
      <span class="inline-block bg-primary-100 text-primary-700 text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full">
        {label}
      </span>
      <span class="text-sm text-gray-400">{duration}</span>
    </div>
    <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600 transition-colors">
      {title}
    </h3>
    <p class="text-gray-600 text-sm leading-relaxed line-clamp-2 mb-4">
      {description}
    </p>
    <div class="flex items-center text-sm text-gray-400">
      <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
      <time datetime={pubDate.toISOString()}>{formattedDate}</time>
    </div>
  </article>
</a>
