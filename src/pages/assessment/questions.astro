---
import '../../styles/global.css';
import { Image } from 'astro:assets';
import logoDark from '../../assets/images/Agiletactix-logo-dark-mode.png';
import { QUESTIONS, MAX_DIMENSION_RAW, TOTAL_QUESTIONS } from '../../lib/assessment/questions';

const pageTitle = 'Agile-AI Readiness Assessment — AgileTactix';
const pageDescription = 'Take the Agile-AI Readiness Assessment. 25 questions, 5 minutes, instant results.';

// Serialize for client-side use
const questionsData = QUESTIONS.map(q => ({
  id: q.id,
  dimension: q.dimension,
  text: q.text,
  options: q.options,
}));
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDescription} />
  <meta name="robots" content="noindex" />
  <link rel="icon" type="image/png" href="/favicon.png" />
</head>
<body>

<a href="#main-content" class="aq-skip-link">Skip to main content</a>

<!-- Minimal assessment header -->
<header class="aq-header" aria-label="Assessment header">
  <div class="aq-header-inner">
    <div class="aq-header-logo" aria-hidden="true">
      <Image src={logoDark} alt="" class="aq-logo-img" />
    </div>
    <div class="aq-header-progress" id="aq-header-progress" aria-hidden="true">
      <div
        class="aq-progress-track"
        role="progressbar"
        id="aq-progress-bar"
        aria-valuenow="4"
        aria-valuemin="0"
        aria-valuemax="100"
        aria-label="Assessment progress"
      >
        <div class="aq-progress-fill" id="aq-progress-fill" style="width: 4%"></div>
      </div>
      <div class="aq-progress-meta">
        <span class="aq-q-counter" id="aq-q-counter">Question 1 of 25</span>
        <span class="aq-dim-label" id="aq-dim-label"></span>
      </div>
    </div>
    <div class="aq-header-spacer" aria-hidden="true"></div>
  </div>
</header>

<div class="aq-wrap">

  <!-- Subtle mesh background -->
  <div class="aq-bg-mesh" aria-hidden="true"></div>

  <main class="aq-main" id="main-content" tabindex="-1">

    <!-- Intro screen -->
    <div id="aq-intro" class="aq-card">
      <div class="aq-eyebrow">
        <span class="aq-dot"></span>Agile-AI Readiness Assessment
      </div>
      <h1 class="aq-intro-h1">Find out where you actually stand.</h1>
      <p class="aq-intro-p">
        Five dimensions. 25 questions. One honest profile of where you sit in the Facilitator → Builder → Orchestrator framework — and the single gap costing you the most right now.
      </p>
      <div class="aq-meta-row">
        <span class="aq-meta-chip">
          <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" width="14" height="14"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          25 questions
        </span>
        <span class="aq-meta-chip">
          <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" width="14" height="14"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          5 minutes
        </span>
        <span class="aq-meta-chip">
          <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" width="14" height="14"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          Free
        </span>
      </div>
      <button type="button" id="aq-start-btn" class="aq-cta-btn">
        Start Assessment →
      </button>
      <p class="aq-fine">Built by <strong>Danny Liu</strong> · taught to <strong>13,000+</strong> agile professionals</p>
    </div>

    <!-- Question screen -->
    <div id="aq-question" class="aq-card hidden">
      <!-- Keyboard shortcut hint (screen reader only) -->
      <p class="aq-sr-only" id="aq-keyboard-hint">Press 1 through 4 to select an answer, Enter to advance, or Backspace to go back.</p>

      <!-- Live region for question transitions -->
      <div aria-live="polite" aria-atomic="true" class="aq-sr-only" id="aq-live-region"></div>

      <!-- Question text -->
      <p class="aq-q-text" id="aq-q-text" tabindex="-1"></p>

      <!-- Options -->
      <div class="aq-options" id="aq-options"></div>

      <!-- Navigation -->
      <div class="aq-nav">
        <button type="button" id="aq-back-btn" class="aq-back-btn" disabled>← Back</button>
        <div class="aq-nav-right">
          <button type="button" id="aq-next-btn" class="aq-cta-btn aq-next-btn" disabled><span>Next →</span></button>
          <span class="aq-key-hint" id="aq-key-hint">press <kbd>Enter</kbd> ↵</span>
        </div>
      </div>
    </div>

    <!-- Email capture screen -->
    <div id="aq-email" class="aq-card hidden">
      <div class="aq-eyebrow"><span class="aq-dot"></span>Almost there</div>
      <h2 class="aq-email-h2">Where should we send your results?</h2>
      <p class="aq-email-p">Your Facilitator / Builder / Orchestrator profile plus a tailored action plan — instant, free, in your inbox.</p>

      <form id="aq-email-form" class="aq-form" novalidate>
        <div class="aq-field">
          <label for="aq-first-name" class="aq-label">First Name</label>
          <input type="text" id="aq-first-name" name="first_name" required placeholder="Your first name" class="aq-input" />
        </div>
        <div class="aq-field">
          <label for="aq-email-input" class="aq-label">Email Address</label>
          <input type="email" id="aq-email-input" name="email" required placeholder="you@example.com" class="aq-input" />
        </div>
        <p class="aq-consent-text">By submitting, you'll receive your results and practitioner insights on AI-powered agile. Unsubscribe anytime. <a href="/privacy" class="aq-privacy-link">Privacy Policy</a></p>
        <div id="aq-form-error" class="aq-form-error hidden"></div>
        <button type="submit" id="aq-submit-btn" class="aq-cta-btn aq-submit-btn">
          <span id="aq-submit-label">Get My Results →</span>
        </button>
      </form>
    </div>

    <!-- Loading screen -->
    <div id="aq-loading" class="aq-card hidden aq-loading-card">
      <div class="aq-spinner"></div>
      <p class="aq-loading-text">Calculating your readiness profile...</p>
    </div>

  </main>
</div>

<!-- Welcome-back dialog -->
<div id="aq-resume-backdrop" class="aq-resume-backdrop hidden" aria-hidden="true">
  <div
    id="aq-resume-dialog"
    class="aq-resume-dialog"
    role="dialog"
    aria-modal="true"
    aria-labelledby="aq-resume-title"
  >
    <h2 class="aq-resume-title" id="aq-resume-title">Welcome back</h2>
    <p class="aq-resume-body" id="aq-resume-body">You're on question 1 of 25</p>
    <div class="aq-resume-actions">
      <button type="button" id="aq-resume-continue" class="aq-cta-btn aq-resume-continue-btn">Continue where I left off</button>
      <button type="button" id="aq-resume-fresh" class="aq-resume-fresh-btn">Start fresh</button>
    </div>
  </div>
</div>

<script is:inline define:vars={{ questionsData, MAX_DIMENSION_RAW, TOTAL_QUESTIONS }}>
(function () {
  var STORAGE_KEY = 'agiletactix_assessment_v1';
  var STORAGE_VERSION = 1;
  var MAX_AGE_MS = 30 * 24 * 60 * 60 * 1000; // 30 days

  // ── localStorage helpers ─────────────────────────────────────────────────
  function saveProgress() {
    try {
      var data = {
        version: STORAGE_VERSION,
        startedAt: state.startedAt,
        updatedAt: Date.now(),
        currentIndex: state.currentIndex,
        answers: state.answers,
      };
      localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
    } catch (e) {}
  }

  function loadProgress() {
    try {
      var raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return null;
      var data = JSON.parse(raw);
      if (!data || data.version !== STORAGE_VERSION) return null;
      if (Date.now() - data.startedAt > MAX_AGE_MS) return null;
      return data;
    } catch (e) { return null; }
  }

  function clearProgress() {
    try { localStorage.removeItem(STORAGE_KEY); } catch (e) {}
  }

  // ── State ────────────────────────────────────────────────────────────────
  var state = {
    currentIndex: 0,
    startedAt: 0,
    answers: {},
  };

  var QUESTIONS = questionsData;

  var DIMENSION_NAMES = {
    d_atlassian:  'Atlassian Depth',
    d_automation: 'Automation Output',
    d_ai:         'AI Fluency',
    d_influence:  'Influence Range',
    d_org:        'Org Readiness',
  };

  // ── DOM refs ─────────────────────────────────────────────────────────────
  var introCard    = document.getElementById('aq-intro');
  var questionCard = document.getElementById('aq-question');
  var emailCard    = document.getElementById('aq-email');
  var loadingCard  = document.getElementById('aq-loading');

  var progressFill = document.getElementById('aq-progress-fill');
  var progressBar  = document.getElementById('aq-progress-bar');
  var qCounter     = document.getElementById('aq-q-counter');
  var dimLabel     = document.getElementById('aq-dim-label');
  var qText        = document.getElementById('aq-q-text');
  var liveRegion   = document.getElementById('aq-live-region');
  var optionsEl    = document.getElementById('aq-options');
  var backBtn      = document.getElementById('aq-back-btn');
  var nextBtn      = document.getElementById('aq-next-btn');
  var nextLabel    = nextBtn ? nextBtn.querySelector('span') : null;

  var submitBtn    = document.getElementById('aq-submit-btn');
  var submitLabel  = document.getElementById('aq-submit-label');
  var formError    = document.getElementById('aq-form-error');

  var resumeBackdrop   = document.getElementById('aq-resume-backdrop');
  var resumeDialog     = document.getElementById('aq-resume-dialog');
  var resumeBody       = document.getElementById('aq-resume-body');
  var resumeContinue   = document.getElementById('aq-resume-continue');
  var resumeFresh      = document.getElementById('aq-resume-fresh');

  var headerProgress   = document.getElementById('aq-header-progress');

  // ── Helpers ──────────────────────────────────────────────────────────────
  function showOnly(el) {
    [introCard, questionCard, emailCard, loadingCard].forEach(function (c) {
      if (c) c.classList.add('hidden');
    });
    if (el) el.classList.remove('hidden');
    // Show header progress bar only during the question screen
    if (headerProgress) {
      if (el === questionCard) {
        headerProgress.removeAttribute('aria-hidden');
        headerProgress.classList.remove('aq-header-progress-hidden');
      } else {
        headerProgress.setAttribute('aria-hidden', 'true');
        headerProgress.classList.add('aq-header-progress-hidden');
      }
    }
  }

  function currentQuestion() {
    return QUESTIONS[state.currentIndex];
  }

  function currentAnswer() {
    var q = currentQuestion();
    return q ? state.answers[q.id] : undefined;
  }

  // ── Render ───────────────────────────────────────────────────────────────
  function renderQuestion() {
    var q = currentQuestion();
    if (!q) return;

    var idx = state.currentIndex;
    var pct = Math.round(((idx + 1) / TOTAL_QUESTIONS) * 100);

    if (progressFill) progressFill.style.width = pct + '%';
    if (progressBar) progressBar.setAttribute('aria-valuenow', String(pct));
    if (qCounter) qCounter.textContent = 'Question ' + (idx + 1) + ' of ' + TOTAL_QUESTIONS;
    if (dimLabel) dimLabel.textContent = DIMENSION_NAMES[q.dimension] || '';
    if (qText) qText.textContent = q.text;
    if (liveRegion) liveRegion.textContent = 'Question ' + (idx + 1) + ' of ' + TOTAL_QUESTIONS + '. ' + q.text;

    // Build option cards
    if (optionsEl) {
      optionsEl.innerHTML = '';
      var answerVal = state.answers[q.id];
      q.options.forEach(function (opt) {
        var isSelected = answerVal === opt.value;
        var lbl = document.createElement('label');
        lbl.className = 'aq-option' + (isSelected ? ' aq-option-selected' : '');

        var inp = document.createElement('input');
        inp.type = 'radio';
        inp.name = q.id;
        inp.value = String(opt.value);
        inp.checked = isSelected;
        inp.className = 'aq-option-radio';

        var txt = document.createElement('span');
        txt.className = 'aq-option-text';
        txt.textContent = opt.label;

        inp.addEventListener('change', function () {
          state.answers[q.id] = opt.value;
          saveProgress();
          renderQuestion();
          updateNav();
        });

        lbl.appendChild(inp);
        lbl.appendChild(txt);
        optionsEl.appendChild(lbl);
      });
    }

    updateNav();
  }

  var keyHint = document.getElementById('aq-key-hint');

  function updateNav() {
    var answered = currentAnswer() !== undefined;
    var isLast   = state.currentIndex === TOTAL_QUESTIONS - 1;
    var isFirst  = state.currentIndex === 0;

    if (backBtn) backBtn.disabled = isFirst;
    if (nextBtn) nextBtn.disabled = !answered;

    if (nextLabel) {
      nextLabel.textContent = (isLast && answered) ? 'Continue →' : 'Next →';
    }

    if (keyHint) {
      if (answered) {
        keyHint.classList.add('visible');
      } else {
        keyHint.classList.remove('visible');
      }
    }
  }

  // ── Scoring ──────────────────────────────────────────────────────────────
  function calculateScores() {
    var dimRaws = {
      d_atlassian:  0,
      d_automation: 0,
      d_ai:         0,
      d_influence:  0,
      d_org:        0,
    };

    QUESTIONS.forEach(function (q) {
      var val = state.answers[q.id];
      if (typeof val === 'number') {
        dimRaws[q.dimension] = (dimRaws[q.dimension] || 0) + val;
      }
    });

    var normalized = {};
    Object.keys(dimRaws).forEach(function (dim) {
      normalized[dim] = Math.round((dimRaws[dim] / MAX_DIMENSION_RAW) * 100);
    });

    return normalized;
  }

  // ── Welcome-back dialog ──────────────────────────────────────────────────
  function showResumeDialog(savedIndex) {
    if (resumeBody) resumeBody.textContent = 'You\'re on question ' + (savedIndex + 1) + ' of ' + TOTAL_QUESTIONS;
    if (resumeBackdrop) {
      resumeBackdrop.classList.remove('hidden');
      resumeBackdrop.removeAttribute('aria-hidden');
    }
    if (resumeContinue) resumeContinue.focus();
  }

  function hideResumeDialog() {
    if (resumeBackdrop) {
      resumeBackdrop.classList.add('hidden');
      resumeBackdrop.setAttribute('aria-hidden', 'true');
    }
  }

  if (resumeContinue) {
    resumeContinue.addEventListener('click', function () {
      hideResumeDialog();
      renderQuestion();
      showOnly(questionCard);
      if (qText) qText.focus();
    });
  }

  if (resumeFresh) {
    resumeFresh.addEventListener('click', function () {
      clearProgress();
      state.currentIndex = 0;
      state.startedAt = Date.now();
      state.answers = {};
      hideResumeDialog();
      renderQuestion();
      showOnly(questionCard);
      if (qText) qText.focus();
    });
  }

  // ── Event handlers ───────────────────────────────────────────────────────
  var startBtn = document.getElementById('aq-start-btn');
  if (startBtn) {
    startBtn.addEventListener('click', function () {
      state.currentIndex = 0;
      state.startedAt = Date.now();
      state.answers = {};
      saveProgress();
      renderQuestion();
      showOnly(questionCard);
      if (qText) qText.focus();
    });
  }

  if (backBtn) {
    backBtn.addEventListener('click', function () {
      if (state.currentIndex > 0) {
        state.currentIndex--;
        saveProgress();
        renderQuestion();
      }
    });
  }

  if (nextBtn) {
    nextBtn.addEventListener('click', function () {
      if (currentAnswer() === undefined) return;

      if (state.currentIndex === TOTAL_QUESTIONS - 1) {
        // Go to email capture
        showOnly(emailCard);
      } else {
        state.currentIndex++;
        saveProgress();
        renderQuestion();
      }
    });
  }

  // Keyboard navigation
  document.addEventListener('keydown', function (e) {
    // Only active on question screen
    if (!questionCard || questionCard.classList.contains('hidden')) return;

    var q = currentQuestion();
    if (!q) return;

    // Number keys 1-4 select options
    var num = parseInt(e.key, 10);
    if (num >= 1 && num <= q.options.length) {
      e.preventDefault();
      state.answers[q.id] = q.options[num - 1].value;
      saveProgress();
      renderQuestion();
      updateNav();
      return;
    }

    // Enter advances if answered
    if (e.key === 'Enter' && currentAnswer() !== undefined) {
      e.preventDefault();
      if (state.currentIndex === TOTAL_QUESTIONS - 1) {
        showOnly(emailCard);
        var firstInput = document.getElementById('aq-first-name');
        if (firstInput) firstInput.focus();
      } else {
        state.currentIndex++;
        saveProgress();
        renderQuestion();
      }
    }

    // Backspace goes back
    if (e.key === 'Backspace' && state.currentIndex > 0) {
      e.preventDefault();
      state.currentIndex--;
      saveProgress();
      renderQuestion();
    }
  });

  // Email form submission
  var emailForm = document.getElementById('aq-email-form');
  if (emailForm) {
    emailForm.addEventListener('submit', function (e) {
      e.preventDefault();

      var firstNameEl = document.getElementById('aq-first-name');
      var emailEl     = document.getElementById('aq-email-input');

      var firstName = firstNameEl ? firstNameEl.value.trim() : '';
      var email     = emailEl     ? emailEl.value.trim()     : '';

      // Basic client-side validation
      if (!firstName || !email) {
        if (formError) {
          formError.textContent = 'Please enter your first name and email address.';
          formError.classList.remove('hidden');
        }
        return;
      }

      if (formError) formError.classList.add('hidden');
      if (submitBtn) submitBtn.setAttribute('disabled', 'true');
      if (submitLabel) submitLabel.textContent = 'Calculating...';

      showOnly(loadingCard);

      var scores = calculateScores();

      fetch('/api/assessment/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email: email,
          first_name: firstName,
          consent_marketing: true,
          scores: scores
        })
      }).then(function(res) {
        return res.json();
      }).then(function(data) {
        if (data.token) {
          clearProgress();
          window.location.href = '/assessment/results?t=' + data.token;
        } else {
          if (formError) {
            formError.textContent = 'Something went wrong. Please try again.';
            formError.classList.remove('hidden');
          }
          if (submitBtn) submitBtn.removeAttribute('disabled');
          if (submitLabel) submitLabel.textContent = 'Get My Results →';
          showOnly(emailCard);
        }
      }).catch(function() {
        if (formError) {
          formError.textContent = 'Something went wrong. Please try again.';
          formError.classList.remove('hidden');
        }
        if (submitBtn) submitBtn.removeAttribute('disabled');
        if (submitLabel) submitLabel.textContent = 'Get My Results →';
        showOnly(emailCard);
      });
    });
  }

  // ── Page-load: check for saved progress ──────────────────────────────────
  var saved = loadProgress();
  if (saved && saved.currentIndex > 0) {
    state.currentIndex = saved.currentIndex;
    state.startedAt    = saved.startedAt;
    state.answers      = saved.answers || {};
    showResumeDialog(saved.currentIndex);
  }
  // If no saved progress, show intro screen as normal (already visible by default)
})();
</script>

<style is:global>
/* ── Option cards — must be global because created via JS createElement ── */
.aq-option {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  width: 100%;
  padding: 16px 20px;
  background: rgba(255,255,255,0.03);
  border: 1.5px solid rgba(255,255,255,0.08);
  border-radius: 10px;
  color: #d1d5db;
  cursor: pointer;
  transition: border-color 200ms ease, background 200ms ease, color 200ms ease;
  user-select: none;
  text-align: left;
  font-size: 15px;
  line-height: 1.5;
  font-family: Inter, -apple-system, BlinkMacSystemFont, sans-serif;
  box-sizing: border-box;
}

.aq-option:hover {
  border-color: #60a5fa;
  background: rgba(96,165,250,0.06);
  color: #f3f4f6;
}

.aq-option-selected {
  border-color: #60a5fa;
  background: rgba(96,165,250,0.12);
  color: #ffffff;
  font-weight: 600;
}

.aq-option-radio {
  appearance: none;
  -webkit-appearance: none;
  width: 18px;
  height: 18px;
  min-width: 18px;
  border: 2px solid rgba(255,255,255,0.2);
  border-radius: 50%;
  background: transparent;
  cursor: pointer;
  margin-top: 1px;
  flex-shrink: 0;
  position: relative;
  transition: border-color 150ms ease;
}

.aq-option:hover .aq-option-radio {
  border-color: #60a5fa;
}

.aq-option-radio:checked {
  border-color: #60a5fa;
  background: #60a5fa;
}

.aq-option-radio:checked::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #0a0a0a;
}

.aq-option-radio:focus-visible {
  outline: 2px solid #60a5fa;
  outline-offset: 3px;
}

.aq-sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

.aq-option-text {
  flex: 1;
  line-height: 1.5;
}
</style>

<style>
/* ── Skip link ────────────────────────────────────────────────────────────── */
.aq-skip-link {
  position: absolute;
  left: 1rem;
  top: 1rem;
  z-index: 9999;
  padding: 0.5rem 1rem;
  border-radius: 4px;
  background: #294bf3;
  color: #fff;
  font-weight: 600;
  text-decoration: none;
  transform: translateY(-200%);
  transition: transform 0.2s;
}
.aq-skip-link:focus {
  transform: translateY(0);
}

/* ── Minimal assessment header ────────────────────────────────────────────── */
.aq-header {
  position: sticky;
  top: 0;
  z-index: 50;
  height: 64px;
  background: var(--at-black);
  border-bottom: 1px solid rgba(255,255,255,0.08);
  display: flex;
  align-items: center;
}

.aq-header-inner {
  width: 100%;
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 24px;
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  gap: 16px;
}

.aq-header-logo {
  display: flex;
  align-items: center;
  pointer-events: none;
  user-select: none;
}

.aq-logo-img {
  height: 28px;
  width: auto;
}

.aq-header-progress {
  min-width: 280px;
  max-width: 400px;
  transition: opacity 200ms ease;
}

.aq-header-progress-hidden {
  opacity: 0;
  pointer-events: none;
}

.aq-header-spacer {
  display: block;
}

@media (max-width: 640px) {
  .aq-header-inner {
    grid-template-columns: auto 1fr;
    gap: 12px;
    padding: 0 16px;
  }
  .aq-header-spacer {
    display: none;
  }
  .aq-header-progress {
    min-width: 0;
    max-width: none;
  }
}

/* ── Page wrapper ─────────────────────────────────────────────────────────── */
.aq-wrap {
  background: var(--at-black);
  color: var(--fg-1);
  min-height: calc(100vh - 64px);
  position: relative;
  font-family: var(--font-sans);
  display: flex;
  flex-direction: column;
}

.aq-bg-mesh {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 0;
  background: var(--grad-hero-mesh);
  opacity: 0.6;
}

.aq-main {
  position: relative;
  z-index: 1;
  flex: 1;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding: 64px 24px 80px;
}

/* ── Card ─────────────────────────────────────────────────────────────────── */
.aq-card {
  width: 100%;
  max-width: 680px;
  background: var(--grad-dark-card);
  border: 1px solid var(--border-blue);
  border-radius: 16px;
  padding: 44px 48px;
  box-shadow:
    0 30px 60px -20px rgba(0,0,0,0.6),
    0 0 0 1px rgba(37,99,235,0.1),
    0 0 80px -10px rgba(37,99,235,0.18);
}

@media (max-width: 640px) {
  .aq-card { padding: 28px 24px; }
}

.hidden { display: none !important; }

/* ── Eyebrow ──────────────────────────────────────────────────────────────── */
.aq-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 7px 14px;
  background: rgba(37,99,235,0.12);
  border: 1px solid var(--border-blue);
  border-radius: 999px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--at-blue-300);
  margin-bottom: 24px;
}

.aq-dot {
  width: 7px;
  height: 7px;
  border-radius: 999px;
  background: var(--at-blue-400);
  box-shadow: 0 0 8px var(--at-blue-400);
  animation: aq-pulse 2s infinite;
  display: inline-block;
  flex-shrink: 0;
}
@keyframes aq-pulse { 0%,100%{opacity:1;} 50%{opacity:.45;} }

/* ── Intro screen ─────────────────────────────────────────────────────────── */
.aq-intro-h1 {
  font-size: clamp(30px, 4vw, 44px);
  font-weight: 800;
  line-height: 1.1;
  letter-spacing: -0.03em;
  margin-bottom: 16px;
  color: var(--fg-1);
}

.aq-intro-p {
  font-size: 17px;
  line-height: 1.6;
  color: var(--fg-2);
  margin-bottom: 28px;
  font-weight: 400;
}

.aq-meta-row {
  display: flex;
  gap: 20px;
  flex-wrap: wrap;
  margin-bottom: 36px;
}

.aq-meta-chip {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-size: 13px;
  color: var(--fg-3);
}

.aq-meta-chip svg {
  color: var(--at-blue-400);
  flex-shrink: 0;
}

.aq-fine {
  margin-top: 16px;
  font-size: 13px;
  color: var(--fg-3);
}

.aq-fine strong {
  color: var(--fg-2);
  font-weight: 600;
}

/* ── CTA button ───────────────────────────────────────────────────────────── */
.aq-cta-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 16px 32px;
  background: var(--grad-cta);
  color: #fff;
  border: none;
  border-radius: 12px;
  font-size: 16px;
  font-weight: 700;
  font-family: inherit;
  cursor: pointer;
  text-decoration: none;
  transition: transform 200ms var(--ease-out), box-shadow 200ms var(--ease-out);
  box-shadow: var(--glow-blue-md);
}

.aq-cta-btn:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: var(--glow-blue-lg);
}

.aq-cta-btn:focus-visible {
  outline: 3px solid #60a5fa;
  outline-offset: 3px;
}

.aq-cta-btn:disabled {
  opacity: 0.38;
  cursor: not-allowed;
  transform: none;
  box-shadow: none;
}

/* ── Progress ─────────────────────────────────────────────────────────────── */
.aq-progress-track {
  width: 100%;
  height: 4px;
  background: rgba(255,255,255,0.08);
  border-radius: 999px;
  overflow: hidden;
  margin-bottom: 10px;
}

.aq-progress-fill {
  height: 100%;
  background: var(--grad-cta);
  border-radius: 999px;
  transition: width 300ms var(--ease-out);
}

.aq-progress-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.aq-q-counter {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--fg-4);
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

.aq-dim-label {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--at-blue-300);
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

/* ── Question text ────────────────────────────────────────────────────────── */
.aq-q-text {
  font-size: 22px;
  font-weight: 700;
  color: var(--fg-1);
  line-height: 1.35;
  letter-spacing: -0.01em;
  margin-bottom: 28px;
  user-select: none;
  outline: none;
}

/* ── Options container ────────────────────────────────────────────────────── */
.aq-options {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 32px;
}

/* ── Nav row ──────────────────────────────────────────────────────────────── */
.aq-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.aq-back-btn {
  background: none;
  border: none;
  color: var(--fg-4);
  font-size: 14px;
  font-family: inherit;
  cursor: pointer;
  padding: 8px 0;
  transition: color 150ms ease;
}

.aq-back-btn:hover:not(:disabled) {
  color: var(--fg-1);
}

.aq-back-btn:focus-visible {
  outline: 2px solid #60a5fa;
  outline-offset: 2px;
  border-radius: 4px;
}

.aq-back-btn:disabled {
  opacity: 0;
  cursor: default;
}

.aq-nav-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
}

.aq-next-btn {
  padding: 14px 28px;
  font-size: 15px;
}

.aq-key-hint {
  font-size: 12px;
  color: var(--fg-4);
  opacity: 0;
  transition: opacity 300ms ease;
}

.aq-key-hint.visible {
  opacity: 1;
}

.aq-key-hint kbd {
  display: inline-block;
  padding: 1px 6px;
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 4px;
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--fg-2);
}

/* ── Email capture ────────────────────────────────────────────────────────── */
.aq-email-h2 {
  font-size: 28px;
  font-weight: 800;
  letter-spacing: -0.02em;
  line-height: 1.15;
  margin-bottom: 12px;
  color: var(--fg-1);
}

.aq-email-p {
  font-size: 16px;
  color: var(--fg-2);
  line-height: 1.6;
  margin-bottom: 32px;
  font-weight: 400;
}

.aq-form {
  display: flex;
  flex-direction: column;
  gap: 18px;
}

.aq-field {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.aq-label {
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.03em;
  color: var(--fg-2);
  text-transform: uppercase;
}

.aq-input {
  background: rgba(255,255,255,0.04);
  border: 1.5px solid rgba(255,255,255,0.1);
  border-radius: 10px;
  padding: 14px 16px;
  color: var(--fg-1);
  font-family: inherit;
  font-size: 15px;
  outline: none;
  transition: border-color 150ms ease, background 150ms ease;
  width: 100%;
  box-sizing: border-box;
}

.aq-input::placeholder {
  color: var(--fg-4);
}

.aq-input:focus,
.aq-input:focus-visible {
  border-color: var(--at-blue-400);
  background: rgba(96,165,250,0.05);
  outline: 2px solid rgba(96,165,250,0.5);
  outline-offset: 2px;
}

.aq-consent-text {
  font-size: 13px;
  color: var(--fg-3);
  line-height: 1.55;
  padding: 4px 0;
}

.aq-privacy-link {
  color: var(--at-blue-400);
  text-decoration: none;
}

.aq-privacy-link:hover {
  text-decoration: underline;
}

.aq-privacy-link:focus-visible {
  outline: 2px solid #60a5fa;
  outline-offset: 2px;
  border-radius: 2px;
}

.aq-form-error {
  background: rgba(248,113,113,0.1);
  border: 1px solid rgba(248,113,113,0.3);
  border-radius: 8px;
  padding: 12px 14px;
  font-size: 14px;
  color: #fca5a5;
  line-height: 1.5;
}

.aq-submit-btn {
  width: 100%;
  font-size: 16px;
  padding: 18px 32px;
}

/* ── Loading screen ───────────────────────────────────────────────────────── */
.aq-loading-card {
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24px;
  padding: 64px 48px;
}

.aq-spinner {
  width: 48px;
  height: 48px;
  border: 3px solid rgba(96,165,250,0.2);
  border-top-color: var(--at-blue-400);
  border-radius: 50%;
  animation: aq-spin 0.8s linear infinite;
}

@keyframes aq-spin { to { transform: rotate(360deg); } }

.aq-loading-text {
  font-size: 17px;
  color: var(--fg-2);
  font-weight: 500;
}

/* ── Welcome-back dialog ──────────────────────────────────────────────────── */
.aq-resume-backdrop {
  position: fixed;
  inset: 0;
  z-index: 200;
  background: rgba(0,0,0,0.72);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24px;
}

.aq-resume-dialog {
  width: 100%;
  max-width: 480px;
  background: var(--grad-dark-card);
  border: 1px solid var(--border-blue);
  border-radius: 16px;
  padding: 40px 44px;
  box-shadow:
    0 30px 60px -20px rgba(0,0,0,0.6),
    0 0 0 1px rgba(37,99,235,0.1),
    0 0 80px -10px rgba(37,99,235,0.18);
}

@media (max-width: 480px) {
  .aq-resume-dialog { padding: 28px 24px; }
}

.aq-resume-title {
  font-size: 26px;
  font-weight: 800;
  letter-spacing: -0.02em;
  color: var(--fg-1);
  margin-bottom: 10px;
}

.aq-resume-body {
  font-size: 16px;
  color: var(--fg-2);
  line-height: 1.55;
  margin-bottom: 32px;
}

.aq-resume-actions {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.aq-resume-continue-btn {
  width: 100%;
  font-size: 15px;
  padding: 16px 28px;
}

.aq-resume-fresh-btn {
  background: none;
  border: 1.5px solid rgba(255,255,255,0.12);
  border-radius: 12px;
  color: var(--fg-3);
  font-family: inherit;
  font-size: 14px;
  font-weight: 500;
  padding: 12px 28px;
  cursor: pointer;
  transition: border-color 150ms ease, color 150ms ease;
  width: 100%;
}

.aq-resume-fresh-btn:hover {
  border-color: rgba(255,255,255,0.25);
  color: var(--fg-1);
}

.aq-resume-fresh-btn:focus-visible {
  outline: 2px solid #60a5fa;
  outline-offset: 3px;
}
</style>

</body>
</html>
