}

/* Hero — full-bleed tier illustration behind text */
.atr-hero {
  position: relative;
  min-height: 420px;
  overflow: hidden;
}
.atr-hero-text { position: relative; z-index: 2; }
.atr-hero-img {
  position: absolute;
  inset: 0;
  z-index: 1;
  pointer-events: none;
  mask-image: radial-gradient(ellipse 80% 80% at 65% 45%, black 15%, transparent 65%);
  -webkit-mask-image: radial-gradient(ellipse 80% 80% at 65% 45%, black 15%, transparent 65%);
}
.atr-hero-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  opacity: 0;
  transition: opacity 600ms ease;
}
.atr-hero-img img.loaded { opacity: 0.55; }
@media (max-width: 900px) {
  .atr-hero-img { display: none; }
}

/* Header */
.atr-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 8px 16px;
  background: rgba(37,99,235,0.12);
  border: 1px solid var(--border-blue);
  border-radius: 999px;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--at-blue-300);
