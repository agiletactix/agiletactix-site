.atr-zone-key { display: flex; flex-direction: column; gap: 8px; font-family: var(--font-mono); font-size: 11px; color: var(--fg-4); }
.atr-zrow { display: flex; align-items: center; gap: 8px; }
.atr-zrow-active { color: var(--at-blue-300); font-weight: 700; }
