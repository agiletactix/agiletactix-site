  max-width: 720px;
}

/* Inbox note */
.atr-inbox-note {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 12px 18px;
  margin-top: 24px;
  background: rgba(96,165,250,0.08);
  border: 1px solid rgba(96,165,250,0.2);
  border-radius: 10px;
  font-size: 14px;
