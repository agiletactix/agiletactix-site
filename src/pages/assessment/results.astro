}
.atr-reco p.reco-lede strong { color: #fff; font-weight: 700; }
.atr-reco p.reco-support {
  font-size: 15.5px; color: var(--fg-3); line-height: 1.65;
  padding-left: 18px; border-left: 1px dashed var(--border-dark);
  max-width: 760px;
}
.atr-next { margin-top: 28px; display: flex; flex-direction: column; gap: 10px; }
.atr-next-title { font-size: 12px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--fg-4); margin-bottom: 4px; }
.atr-step {
  display: flex;
  gap: 14px;
  align-items: flex-start;
  font-size: 15px;
  color: var(--fg-2);
  line-height: 1.5;
  padding: 10px 0;
  border-top: 1px solid var(--border-dark);
}
.atr-step:first-of-type { border-top: 0; }
.atr-step-n { font-family: var(--font-mono); font-size: 13px; font-weight: 700; color: var(--at-blue-400); min-width: 24px; }

/* Offer */
.atr-offer {
  margin-top: 56px;
  padding: 40px 44px;
  background: var(--grad-dark-card);
  border: 1px solid var(--border-blue);
  border-radius: 16px;
  position: relative;
  overflow: hidden;
}
.atr-offer::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 80% 0%, rgba(96,165,250,0.14), transparent 55%);
  pointer-events: none;
}
.atr-offer-eyebrow {
  display: inline-flex;
  align-items: center;
  padding: 6px 14px;
  border-radius: 999px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-bottom: 18px;
  position: relative;
  z-index: 1;
  background: rgba(96,165,250,0.14);
  border: 1px solid var(--border-blue);
  color: var(--at-blue-300);
}
.atr-offer-facilitator .atr-offer-eyebrow { background: rgba(248,113,113,0.12); border-color: rgba(248,113,113,0.4); color: #fca5a5; }
.atr-offer-orchestrator .atr-offer-eyebrow { background: rgba(34,211,238,0.12); border-color: rgba(34,211,238,0.4); color: var(--at-cyan-bright); }
.atr-offer-h2 { font-size: 34px; font-weight: 800; letter-spacing: -0.02em; line-height: 1.15; margin-bottom: 14px; text-wrap: balance; position: relative; z-index: 1; }
.atr-offer-em { }
.atr-offer-facilitator .atr-offer-em { color: #fca5a5; }
.atr-offer-builder .atr-offer-em { color: var(--at-blue-400); }
.atr-offer-orchestrator .atr-offer-em { color: var(--at-cyan-bright); }
.atr-offer-pitch { font-size: 17px; color: var(--fg-2); line-height: 1.6; max-width: 740px; margin-bottom: 26px; position: relative; z-index: 1; }
.atr-offer-list {
  list-style: none;
  padding: 0;
  margin: 0 0 30px;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 10px 24px;
  position: relative;
  z-index: 1;
}
.atr-offer-list li { display: flex; gap: 10px; align-items: flex-start; font-size: 14px; color: var(--fg-2); line-height: 1.5; }
.atr-offer-list li::before { content: '→'; color: var(--at-blue-400); font-weight: 700; flex-shrink: 0; }
.atr-offer-facilitator .atr-offer-list li::before { color: #fca5a5; }
.atr-offer-orchestrator .atr-offer-list li::before { color: var(--at-cyan-bright); }
.atr-offer-row { display: flex; gap: 14px; align-items: center; flex-wrap: wrap; position: relative; z-index: 1; }
.atr-price { font-family: var(--font-display); font-size: 15px; color: var(--fg-3); font-weight: 500; }
.atr-price strong { font-size: 22px; color: #fff; font-weight: 800; letter-spacing: -0.02em; }
.atr-aspiration {
  margin-top: 20px;
  padding: 18px 22px;
  background: rgba(255,255,255,0.03);
  border: 1px dashed rgba(255,255,255,0.14);
  border-radius: 10px;
  font-size: 13px;
  color: var(--fg-3);
  line-height: 1.55;
  position: relative;
  z-index: 1;
}
.atr-aspiration strong { color: var(--fg-1); font-weight: 700; }

/* Actions row (PDF) */
.atr-actions { margin-top: 32px; display: flex; gap: 16px; flex-wrap: wrap; }

/* Share card */
.atr-share-card {
  margin-top: 32px;
  padding: 32px;
  background: rgba(255,255,255,0.03);
  border: 1px solid var(--border-dark);
  border-radius: 16px;
}
.atr-share-eyebrow {
  font-size: 12px;
  font-weight: 800;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--at-blue-400);
  margin-bottom: 6px;
}
.atr-share-sub {
  font-size: 15px;
  color: var(--fg-2);
  margin-bottom: 20px;
}
.atr-share-btns { display: flex; gap: 12px; margin-bottom: 24px; }
.atr-share-btn {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 14px 28px;
  border-radius: 12px;
  font-size: 15px;
  font-weight: 700;
  text-decoration: none;
  color: #fff;
  background: rgba(255,255,255,0.06);
  border: 1px solid var(--border-dark);
  cursor: pointer;
  transition: all 200ms var(--ease-out);
}
.atr-share-btn:hover {
  border-color: var(--at-blue-400);
  color: var(--at-blue-400);
  background: rgba(96,165,250,0.08);
}
.atr-share-btn:focus-visible {
  outline: 3px solid #60a5fa;
  outline-offset: 3px;
}
.atr-share-toggle-row {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  padding: 16px 20px;
  background: rgba(255,255,255,0.03);
  border-radius: 10px;
  margin-bottom: 20px;
}
.atr-toggle { position: relative; display: inline-flex; cursor: pointer; flex-shrink: 0; margin-top: 2px; }
.atr-toggle input { position: absolute; opacity: 0; width: 0; height: 0; }
.atr-toggle input:focus-visible + .atr-toggle-track { outline: 3px solid #60a5fa; outline-offset: 2px; border-radius: 13px; }
.atr-toggle-track {
  width: 48px;
  height: 26px;
  background: rgba(255,255,255,0.12);
  border-radius: 13px;
  transition: background 200ms;
  position: relative;
}
.atr-toggle input:checked + .atr-toggle-track { background: var(--at-blue-500); }
.atr-toggle-thumb {
  position: absolute;
  top: 3px;
  left: 3px;
  width: 20px;
  height: 20px;
  background: #fff;
  border-radius: 50%;
  transition: transform 200ms;
}
.atr-toggle input:checked + .atr-toggle-track .atr-toggle-thumb { transform: translateX(22px); }
.atr-toggle-text { display: flex; flex-direction: column; gap: 2px; }
.atr-toggle-text strong { font-size: 14px; color: var(--fg-1); }
.atr-toggle-desc { font-size: 13px; color: var(--fg-3); }
.atr-share-preview {
  padding: 20px 24px;
  background: rgba(255,255,255,0.03);
  border: 1px dashed rgba(255,255,255,0.1);
  border-radius: 10px;
}
.atr-preview-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--fg-3);
  margin-bottom: 8px;
}
.atr-preview-text {
  font-size: 15px;
  font-style: italic;
  color: var(--fg-2);
  line-height: 1.6;
}

/* CTAs */
.atr-cta {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 16px 30px;
  border-radius: 12px;
  font-size: 16px;
  font-weight: 700;
  text-decoration: none;
  font-family: inherit;
  transition: all 200ms var(--ease-out);
  cursor: pointer;
}
.atr-cta-primary { background: var(--grad-cta); color: #fff; box-shadow: var(--glow-blue-md); border: none; }
.atr-cta-primary:hover { transform: translateY(-2px); box-shadow: var(--glow-blue-lg); }
.atr-cta-primary:focus-visible { outline: 3px solid #60a5fa; outline-offset: 3px; }
.atr-cta-ghost { background: transparent; color: #fff; border: 1px solid var(--border-dark); }
.atr-cta-ghost:hover { border-color: var(--at-blue-400); color: var(--at-blue-400); }
.atr-cta-ghost:focus-visible { outline: 3px solid #60a5fa; outline-offset: 3px; }

/* Waitlist inline form */
.atr-waitlist-form { margin-top: 24px; }
.atr-waitlist-row { display: flex; gap: 12px; }
.atr-waitlist-input {
  flex: 1;
  padding: 14px 18px;
  border-radius: 10px;
  border: 1px solid var(--border-dark);
  background: rgba(255,255,255,0.05);
  color: #fff;
  font-size: 15px;
  font-family: inherit;
  outline: none;
  transition: border-color 200ms;
}
.atr-waitlist-input:focus { border-color: var(--at-blue-400); }
.atr-waitlist-input::placeholder { color: var(--fg-3); }
.atr-waitlist-input:disabled { opacity: 0.5; }
.atr-waitlist-btn { white-space: nowrap; flex-shrink: 0; }
.atr-waitlist-btn:disabled { opacity: 0.7; cursor: default; transform: none !important; }
.atr-waitlist-fine {
  margin-top: 10px;
  font-size: 13px;
  color: var(--fg-3);
}

/* B2B */
.atr-b2b {
  margin-top: 56px;
  padding: 36px 40px;
  background: linear-gradient(135deg, rgba(0,168,204,0.08) 0%, rgba(0,168,204,0.03) 100%);
  border: 1px solid rgba(0,168,204,0.35);
  border-radius: 16px;
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  gap: 32px;
  align-items: center;
}
@media (max-width: 780px) { .atr-b2b { grid-template-columns: 1fr; } }
.atr-b2b-eyebrow { display: inline-block; font-size: 11px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--at-cyan-bright); margin-bottom: 10px; }
.atr-b2b-h3 { font-size: 22px; font-weight: 800; letter-spacing: -0.015em; line-height: 1.25; margin-bottom: 10px; text-wrap: balance; }
.atr-b2b-p { font-size: 14px; line-height: 1.55; color: var(--fg-3); max-width: 520px; }
.atr-b2b-p em { color: var(--at-cyan-bright); font-style: normal; font-weight: 700; }
.atr-b2b-fine { grid-column: 1 / -1; font-size: 12px; color: var(--fg-4); margin-top: -8px; }
.atr-b2b-form { display: flex; gap: 10px; align-items: stretch; flex-direction: column; }
.atr-b2b-input {
  background: rgba(255,255,255,0.04);
  border: 1px solid var(--border-dark);
  border-radius: 10px;
  padding: 14px 16px;
  color: #fff;
  font-family: inherit;
  font-size: 14px;
  outline: none;
  transition: border-color 200ms;
}
.atr-b2b-input:focus { border-color: var(--at-cyan); }
.atr-b2b-btn {
  padding: 14px 24px;
  background: linear-gradient(135deg, var(--at-cyan) 0%, var(--at-cyan-bright) 100%);
  color: var(--at-black);
  font-family: inherit;
  font-size: 14px;
  font-weight: 800;
  letter-spacing: -0.005em;
  border: none;
  border-radius: 10px;
  cursor: pointer;
  transition: all 200ms var(--ease-out);
}
.atr-b2b-btn:hover:not(:disabled) { transform: translateY(-1px); box-shadow: 0 10px 24px -8px rgba(0,168,204,0.5); }
.atr-b2b-btn:disabled { opacity: 0.8; cursor: default; }

/* Back link */
.atr-back { margin-top: 48px; }
.atr-back-link { font-size: 14px; color: var(--fg-4); text-decoration: none; }
.atr-back-link:hover { color: var(--at-blue-400); }
.atr-back-link:focus-visible { outline: 2px solid #60a5fa; outline-offset: 3px; border-radius: 3px; color: var(--at-blue-400); }

/* Print / PDF styles */
@media print {
  * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; color-adjust: exact !important; }
  body, .atr-wrap { background: #0a0a0a !important; color: #fff !important; }
  .atr-particles, .atr-vignette { display: none !important; }
  .atr-topbar .atr-cta, .atr-topbar .atr-cta-ghost { display: none !important; }
  .atr-back { display: none !important; }
  .atr-share-card, .atr-actions { display: none !important; }
  nav, footer { display: none !important; }
  .atr-page { padding: 24px !important; max-width: 100% !important; }
  .atr-hero-card, .atr-breakdown, .atr-reco, .atr-gap-insight, .atr-offer, .atr-b2b {
    break-inside: avoid !important;
    box-shadow: none !important;
  }
  .atr-grid { grid-template-columns: 1fr !important; }
  a { text-decoration: none !important; }
  .atr-offer-btn, .atr-b2b-btn, .atr-waitlist-form { display: none !important; }
}

@media (max-width: 640px) {
  .atr-share-btns { flex-direction: column; }
  .atr-share-toggle-row { flex-direction: column; gap: 10px; }
  .atr-waitlist-row { flex-direction: column; }
}
</style>

</body>
</html>
