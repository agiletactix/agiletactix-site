---
import '../../styles/global.css';
import { Image } from 'astro:assets';
import logoDark from '../../assets/images/Agiletactix-logo-dark-mode.png';
import Footer from '../../components/Footer.astro';

const pageTitle = 'Your Agile-AI Readiness Results — AgileTactix';
const pageDescription = 'See your Agile-AI Readiness profile — Facilitator, Builder, or Orchestrator — and the next step to level up.';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDescription} />
  <meta name="robots" content="noindex" />
  <link rel="icon" type="image/png" href="/favicon.png" />
</head>
<body>

<a href="#main-content" class="atr-skip-link">Skip to main content</a>

<!-- Particles layer (fixed behind all content) -->
<div class="atr-particles-layer" id="particlesLayer" aria-hidden="true">
  <canvas data-particles data-focus-x="0.5" data-focus-y="0.35" data-count="100"></canvas>
  <div class="atr-vignette"></div>
</div>

<div class="atr-page" id="main-content" tabindex="-1">

  <!-- Top bar -->
  <div class="atr-topbar">
    <a href="/" class="atr-logo-link">
      <Image src={logoDark} alt="AgileTactix" class="atr-logo" />
    </a>
    <div class="atr-crumb">Assessment · Results</div>
  </div>

  <!-- Header with tier illustration -->
  <div class="atr-hero">
    <div class="atr-hero-text">
      <div class="atr-eyebrow"><span class="atr-dot"></span>Your Agile-AI Readiness Profile</div>
      <h1 class="atr-h1"><span id="userName"></span>You're <span id="tierArticle">a</span> <span class="atr-blue" id="tierName">Builder</span>. Here's what that means.</h1>
      <p class="atr-lead" id="leadCopy">Your results are loading...</p>
      <div class="atr-inbox-note" id="inboxNote">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        Check your inbox — your full results and personalized breakdown are on the way.
      </div>
    </div>
    <div class="atr-hero-img" id="tierHeroImg" aria-hidden="true">
      <img id="tierImg" src="" alt="" />
    </div>
  </div>

  <!-- Verdict banner -->
  <div class="atr-verdict">
    <div class="atr-score"><span id="totalScore">—</span><span class="atr-of">/100</span></div>
    <div class="atr-tier">
      <div class="atr-tier-label">Tier</div>
      <div class="atr-tier-name" id="tierNameBig">—</div>
      <div class="atr-tier-desc" id="tierDesc"></div>
    </div>
    <div class="atr-zone-key" id="zoneKey"></div>
  </div>

  <!-- Chart + breakdown grid -->
  <div class="atr-grid">

    <div class="atr-chart-card">
      <div class="atr-chart-title">Practitioner Capital × Org Readiness</div>
      <div class="atr-chart-sub">The filled shape is what you control. The cyan ring is the environment you're operating in.</div>
      <div class="atr-radar-wrap">
        <svg class="atr-radar" id="radar" viewBox="-90 -30 680 560"></svg>
      </div>
      <div class="atr-legend">
        <div class="atr-legend-item"><span class="atr-sw atr-sw-cap"></span>Practitioner Capital — 4 things you own (Atlassian Depth, Automation Output, AI Fluency, Influence Range)</div>
        <div class="atr-legend-item"><span class="atr-sw atr-sw-org"></span>Org Readiness — the environmental variable you're working inside</div>
      </div>

      <div class="gap-insight" id="gapInsight">
        <div class="gi-label" id="gapLabel">Gap Analysis</div>
        <div class="gi-body" id="gapBody"></div>
      </div>
    </div>

    <div class="atr-breakdown" id="breakdown"></div>

  </div>

  <!-- Recommendation -->
  <div class="atr-reco">
    <div class="atr-reco-head">
      <span class="atr-pill">Danny's Take</span>
    </div>
    <h2 class="atr-reco-h2" id="recoTitle"></h2>
    <p class="atr-reco-p reco-lede" id="recoBody1"></p>
    <p class="atr-reco-p reco-support" id="recoBody2"></p>
    <div class="atr-next">
      <div class="atr-next-title">Next 30 days</div>
      <div id="nextSteps"></div>
    </div>
  </div>

  <!-- Offer block -->
  <div class="atr-offer" id="offer"></div>

  <!-- Share & PDF -->
  <div class="atr-actions">
    <a class="atr-cta atr-cta-ghost" href="#" onclick="window.print(); return false;">Download as PDF</a>
  </div>

  <div class="atr-share-card">
    <div class="atr-share-eyebrow">SHARE THIS ASSESSMENT</div>
    <p class="atr-share-sub">Help peers find where they stand on the curve.</p>
    <div class="atr-share-btns">
      <a class="atr-share-btn" href="#" id="shareLinkedIn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        LinkedIn
      </a>
      <a class="atr-share-btn" href="#" id="copyLink">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
        Copy link
      </a>
    </div>
    <div class="atr-share-toggle-row">
      <label class="atr-toggle" id="scoreToggle">
        <input type="checkbox" id="includeScore" />
        <span class="atr-toggle-track"><span class="atr-toggle-thumb"></span></span>
      </label>
      <div class="atr-toggle-text">
        <strong>Include my score in the post</strong>
        <span class="atr-toggle-desc">Adds your tier &amp; score to the copied text. LinkedIn shares the link only.</span>
      </div>
    </div>
    <div class="atr-share-preview">
      <div class="atr-preview-label">PREVIEW</div>
      <p class="atr-preview-text" id="sharePreview">"I just took the AgileTactix Agile-AI Readiness Assessment — find out where you stand on the curve."</p>
    </div>
  </div>

  <!-- B2B waitlist -->
  <div class="atr-b2b">
    <div class="atr-b2b-head">
      <div class="atr-b2b-eyebrow">For leaders</div>
      <h3 class="atr-b2b-h3">Leading a team? There's a version of this for you.</h3>
      <p class="atr-b2b-p">The leadership assessment mirrors the same 5 dimensions — but scores your <em>org</em>, not your practitioners. See the gap between what your team has built and what your environment lets them ship.</p>
    </div>
    <form class="atr-b2b-form" id="b2bForm">
      <label for="b2bEmail" class="atr-sr-only">Work email address</label>
      <input type="email" placeholder="work@yourcompany.com" required class="atr-b2b-input" id="b2bEmail" />
      <button type="submit" class="atr-b2b-btn" id="b2bBtn">Join the waitlist</button>
    </form>
    <div class="atr-b2b-fine">No spam. One note when it's ready. Early access for the first 25 orgs.</div>
  </div>

  <div class="atr-back">
    <a href="/assessment" class="atr-back-link">← Back to Assessment</a>
  </div>

</div>

<Footer />

<script src="/particles-bg.js" is:inline></script>

<script is:inline>
/* -------------------------------------------------------
   Data model (outside any IIFE — available to renderResults)
   ------------------------------------------------------- */
var DIMENSIONS = [
  { key: 'atlassian',  name: 'Atlassian Depth',   ptag: 'Practitioner',  desc: 'How much of the stack you actually configure vs. inherit. JQL, automation rules, custom fields, dashboards.' },
  { key: 'automation', name: 'Automation Output',  ptag: 'Practitioner',  desc: 'Have you shipped automations, or just attended workshops. Real rules running in production.' },
  { key: 'ai',         name: 'AI Fluency',         ptag: 'Practitioner',  desc: 'Are you prompting and building, or still watching demos. AI agents, prompt craft, workflow automation.' },
  { key: 'influence',  name: 'Influence Range',    ptag: 'Practitioner',  desc: 'Can you push changes without 3 layers of approval. Scope of the decisions you own.' },
  { key: 'org',        name: 'Org Readiness',      ptag: 'Environmental', desc: 'Structural readiness — value streams, data, governance — what\'s outside your control.' }
];

var TIERS = [
  { name: 'Facilitator',  min: 0,  max: 49,  color: '#f87171',
    img: '/images/tier-facilitator.webp',
    desc: "You coordinate the work. You don't build the systems underneath it — and in 2026 that's the gap that decides who stays." },
  { name: 'Builder',      min: 50, max: 74,  color: '#60a5fa',
    img: '/images/tier-builder.webp',
    desc: "You ship automations and configure the stack. You're closing the gap, one workflow at a time — but you're not yet orchestrating agents that ship while you sleep." },
  { name: 'Orchestrator', min: 75, max: 100, color: '#22d3ee',
    img: '/images/tier-orchestrator.webp',
    desc: "You write the spec. Agents execute it. Sub-agents execute theirs. You're the one designing the system of systems — category-of-one rare." }
];

var TIER_LEAD = {
  Facilitator:  "You coordinate the work. You don't build the systems underneath it yet — and in 2026 that's the gap that decides who stays.",
  Builder:      "You've built real practitioner capital — but a piece of the stack is holding the rest back. The score tells you which one.",
  Orchestrator: "You write the spec. Agents execute it. You're designing the system of systems — and that puts you in a category-of-one rare position."
};

var NEXT_STEPS = {
  Facilitator: [
    "Ship one Atlassian automation rule this week — pick the most painful manual thing you do every sprint and eliminate it.",
    "Set up an AI agent to handle your stand-up notes or sprint recap. Use the output in your next ceremony.",
    "Document what changed in hours-saved and show it to your skip-level. Influence Range starts with proof-of-work."
  ],
  Builder: [
    "Ship one AI agent that automates a ceremony you currently run manually. Stand-up notes, sprint recap, retro summary — pick the one you hate.",
    "Document the before/after in hours-saved and surface it to your skip-level. This becomes your Influence Range leverage.",
    "Pick one Atlassian automation rule you've never written and write it. Public commits to the work close the gap faster than courses."
  ],
  Orchestrator: [
    "Spec a multi-agent workflow end-to-end — including the sub-agents, their inputs, outputs, and failure modes. Build the spec before you build the system.",
    "Run a governance review of your current agent layer: what's auditable, what's not, and what the business risk surface looks like.",
    "Find one other Orchestrator-level practitioner and do a teardown of each other's architecture. The peer review is the forcing function."
  ]
};

var OFFERS = {
  Facilitator: {
    cls: 'atr-offer-facilitator',
    eyebrow: 'Sprint Automation Kit · $27',
    h2: 'Get out of the <span class="atr-offer-em">ceremony trap</span> — before it decides your next role for you.',
    pitch: "You're running the work. You haven't built the systems underneath it yet. The Sprint Automation Kit is 5 production-tested Jira automation patterns — the exact starter rules Facilitators used to cross into Builder within 90 days.",
    bullets: [
      "5 Jira automation patterns used in real enterprise environments",
      "Sprint Sync Engine, Stale Ticket Radar, Sprint Start + Closure Reporting",
      "One-time purchase — build your first automation this weekend",
      "The foundation AI agents depend on"
    ],
    price: { dollars: 27, cadence: 'one-time' },
    url: 'https://checkout.agiletactix.ai/checkout/the-5-step-sprint-automation-kit',
    cta: 'Get the Sprint Automation Kit →',
    aspirationLabel: 'Next tier',
    aspiration: "<strong>Builders</strong> go deeper with the Agile Architect Lab — AI agents, cross-platform automation, and system design. That's the next move once you've shipped your first rules."
  },
  Builder: {
    cls: 'atr-offer-builder',
    eyebrow: 'Founding Community · Coming Soon',
    h2: "You're closer than most. <span class=\"atr-offer-em\">Lock in early</span> before the door closes.",
    pitch: "You ship. You configure. You're already doing the hard thing — but solo. The founding community is ongoing access to AI agent builds, cross-platform automation patterns, and practitioners at your level. Founding members lock in the lowest price for life.",
    bullets: [
      "AI agent builds — from single-tool to cross-platform autonomous systems",
      "Step-by-step architecture for connecting Atlassian, automation, and AI end-to-end",
      "Production-tested patterns from Fortune 500 environments",
      "Founding price locked for life — 100 seats only"
    ],
    price: null,
    url: null,
    waitlistForm: true,
    waitlistFormId: '9376395',
    cta: 'Lock in my spot →',
    aspirationLabel: 'Next tier',
    aspiration: "<strong>Orchestrators</strong> operate at the system-design level. A peer cohort for practitioners at that level is coming — you'll be first to know."
  },
  Orchestrator: {
    cls: 'atr-offer-orchestrator',
    eyebrow: 'Orchestrator Cohort · Coming Soon',
    h2: "You've earned the room. <span class=\"atr-offer-em\">Find your peers.</span>",
    pitch: "You're already operating above the tool layer. You don't need another course — you need the 40 other people doing this at your level. A peer advisory cohort for Orchestrators is launching soon.",
    bullets: [
      "Private Orchestrator roundtable — 40 practitioners max, invite-only",
      "Monthly frontier sessions: spec-driven rollouts, multi-agent systems, governance at scale",
      "First access to new patterns before they go public",
      "Co-authoring opportunities — shape the playbooks the rest of the field reads"
    ],
    price: null,
    url: null,
    waitlistApi: true,
    waitlistTag: 'orchestrator-cohort-waitlist',
    cta: 'Join the waitlist →',
    aspirationLabel: 'The room',
    aspiration: "<strong>You are the aspiration</strong> other tiers are working toward. The cohort is where you trade notes with people who don't need it explained."
  }
};

/* -------------------------------------------------------
   Token check + server fetch
   ------------------------------------------------------- */
(function() {
  var params = new URLSearchParams(window.location.search);
  var token = params.get('t');

  if (!token) {
    window.location.href = '/assessment';
    return;
  }

  fetch('/api/assessment/retrieve?t=' + encodeURIComponent(token))
    .then(function(res) {
      if (!res.ok) {
        window.location.href = '/assessment';
        return null;
      }
      return res.json();
    })
    .then(function(data) {
      if (!data) return;
      renderResults(data);
    })
    .catch(function() {
      window.location.href = '/assessment';
    });
})();

/* -------------------------------------------------------
   Render — called after server data is fetched
   ------------------------------------------------------- */
function renderResults(data) {
  var firstName = data.name || '';
  var userEmail = data.email || '';
  var userNameEl = document.getElementById('userName');
  if (userNameEl && firstName) {
    userNameEl.textContent = firstName + ', ';
  }
  var scores = {
    atlassian:  data.scores.d_atlassian,
    automation: data.scores.d_automation,
    ai:         data.scores.d_ai,
    influence:  data.scores.d_influence,
    org:        data.scores.d_org
  };

  function computeTotal(s) {
    const cap = (s.atlassian + s.automation + s.ai + s.influence) / 4;
    return Math.round(cap * 0.8 + s.org * 0.2);
  }

  function tierFor(total) {
    return TIERS.find(function(t) { return total >= t.min && total <= t.max; }) || TIERS[0];
  }

  /* --- Radar --- */
  function drawRadar(s) {
    const svg = document.getElementById('radar');
    if (!svg) return;
    const cx = 250, cy = 250, R = 180;
    const axes = DIMENSIONS.filter(function(d) { return d.key !== 'org'; });
    const N = 4;

    function pointFor(i, v) {
      const angle = -Math.PI / 2 + i * (2 * Math.PI / N);
      const r = (v / 100) * R;
      return [cx + Math.cos(angle) * r, cy + Math.sin(angle) * r];
    }

    function ptsAtR(r) {
      return axes.map(function(_, i) {
        const a = -Math.PI / 2 + i * (2 * Math.PI / N);
        return [cx + Math.cos(a) * r, cy + Math.sin(a) * r];
      });
    }

    function zonePath(r1, r2) {
      const outer = ptsAtR(r2).map(function(p, k) { return (k === 0 ? 'M' : 'L') + p[0] + ',' + p[1]; }).join(' ') + ' Z';
      const inner = ptsAtR(r1).map(function(p, k) { return (k === 0 ? 'M' : 'L') + p[0] + ',' + p[1]; }).reverse().join(' ') + ' Z';
      return outer + ' ' + inner;
    }

    let html = '';
    const zoneR = [0, R * 0.50, R * 0.75, R];
    const zoneFills = ['rgba(248,113,113,0.07)', 'rgba(96,165,250,0.10)', 'rgba(34,211,238,0.10)'];
    for (let i = 0; i < 3; i++) {
      html += '<path d="' + zonePath(zoneR[i], zoneR[i+1]) + '" fill="' + zoneFills[i] + '" fill-rule="evenodd"/>';
    }

    [0.25, 0.5, 0.75, 1].forEach(function(frac) {
      const pts = ptsAtR(R * frac);
      html += '<polygon points="' + pts.map(function(p) { return p.join(','); }).join(' ') + '" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="1"/>';
    });

    axes.forEach(function(ax, i) {
      const angle = -Math.PI / 2 + i * (2 * Math.PI / N);
      const x = cx + Math.cos(angle) * R;
      const y = cy + Math.sin(angle) * R;
      html += '<line x1="' + cx + '" y1="' + cy + '" x2="' + x + '" y2="' + y + '" stroke="rgba(255,255,255,0.1)" stroke-width="1"/>';
      const lx = cx + Math.cos(angle) * (R + 32);
      const ly = cy + Math.sin(angle) * (R + 28);
      let anchor = 'middle';
      if (Math.cos(angle) > 0.3) anchor = 'start';
      else if (Math.cos(angle) < -0.3) anchor = 'end';
      html += '<text x="' + lx + '" y="' + ly + '" text-anchor="' + anchor + '" fill="#d1d5db" font-family="Inter, sans-serif" font-size="13" font-weight="700" letter-spacing="-0.01em">' + ax.name + '</text>';
      html += '<text x="' + lx + '" y="' + (ly + 16) + '" text-anchor="' + anchor + '" fill="#60a5fa" font-family="\'JetBrains Mono\', monospace" font-size="12" font-weight="700">' + s[ax.key] + '</text>';
    });

    var orgR = (s.org / 100) * R;
    html += '<circle cx="' + cx + '" cy="' + cy + '" r="' + orgR + '" fill="rgba(0,168,204,0.06)" stroke="rgba(0,168,204,0.65)" stroke-width="1.5" stroke-dasharray="4 4"/>';

    var pts = axes.map(function(ax, i) { return pointFor(i, s[ax.key]); });
    html += '<polygon points="' + pts.map(function(p) { return p.join(','); }).join(' ') + '" fill="rgba(96,165,250,0.32)" stroke="#60a5fa" stroke-width="2.5" stroke-linejoin="round"/>';
    pts.forEach(function(p) { html += '<circle cx="' + p[0] + '" cy="' + p[1] + '" r="5" fill="#60a5fa" stroke="#0a0a0a" stroke-width="2"/>'; });
    html += '<circle cx="' + cx + '" cy="' + cy + '" r="2.5" fill="rgba(255,255,255,0.3)"/>';
    html += '<text x="' + (cx + orgR + 6) + '" y="' + (cy - 6) + '" fill="#22d3ee" font-family="\'JetBrains Mono\', monospace" font-size="11" font-weight="700" letter-spacing="0.06em" paint-order="stroke" stroke="#0a0a0a" stroke-width="3">ORG ' + s.org + '</text>';

    svg.innerHTML = html;
  }

  /* --- Breakdown --- */
  function drawBreakdown(s) {
    const el = document.getElementById('breakdown');
    if (!el) return;
    el.innerHTML = DIMENSIONS.map(function(d) {
      const v = s[d.key];
      const isOrg = d.key === 'org';
      return '<div class="atr-row' + (isOrg ? ' atr-row-org' : '') + '">' +
        '<div class="atr-row-top"><div class="atr-row-name">' + d.name + '</div><div class="atr-ptag' + (isOrg ? ' atr-ptag-org' : '') + '">' + d.ptag + '</div></div>' +
        '<div class="atr-row-score"><span class="atr-row-n' + (isOrg ? ' atr-row-n-org' : '') + '">' + v + '</span><span class="atr-row-of">/ 100</span></div>' +
        '<div class="atr-bar"><div class="atr-bar-fill' + (isOrg ? ' atr-bar-fill-org' : '') + '" style="width:' + v + '%"></div></div>' +
        '<div class="atr-row-desc">' + d.desc + '</div>' +
        '</div>';
    }).join('');
  }

  /* --- Verdict + reco --- */
  function drawVerdict(s) {
    const total = computeTotal(s);
    const tier = tierFor(total);

    const totalEl = document.getElementById('totalScore');
    if (totalEl) totalEl.textContent = String(total);

    const tierNameEl = document.getElementById('tierName');
    if (tierNameEl) tierNameEl.textContent = tier.name;

    const articleEl = document.getElementById('tierArticle');
    if (articleEl) articleEl.textContent = /^[aeiou]/i.test(tier.name) ? 'an' : 'a';

    const tierNameBigEl = document.getElementById('tierNameBig');
    if (tierNameBigEl) tierNameBigEl.textContent = tier.name;

    var tierImgEl = document.getElementById('tierImg');
    if (tierImgEl && tier.img) {
      tierImgEl.onload = function() { tierImgEl.classList.add('loaded'); };
      tierImgEl.src = tier.img;
      tierImgEl.alt = tier.name + ' archetype illustration';
    }

    const tierDescEl = document.getElementById('tierDesc');
    if (tierDescEl) tierDescEl.textContent = tier.desc;

    const leadEl = document.getElementById('leadCopy');
    if (leadEl) leadEl.textContent = TIER_LEAD[tier.name] || tier.desc;

    // Zone key
    const zk = document.getElementById('zoneKey');
    if (zk) {
      zk.innerHTML = TIERS.slice().reverse().map(function(t) {
        const active = t.name === tier.name ? ' atr-zrow-active' : '';
        return '<div class="atr-zrow' + active + '"><span class="atr-zswi" style="background:' + t.color + '33;border:1px solid ' + t.color + 'aa"></span>' + t.name + ' <span style="opacity:.6">' + t.min + '–' + t.max + '</span></div>';
      }).join('');
    }

    // Reco
    const prac = ['atlassian', 'automation', 'ai', 'influence'];
    const lowestKey = prac.reduce(function(lo, k) { return s[k] < s[lo] ? k : lo; }, prac[0]);
    const highestKey = prac.reduce(function(hi, k) { return s[k] > s[hi] ? k : hi; }, prac[0]);
    const lowestDim = DIMENSIONS.find(function(d) { return d.key === lowestKey; });
    const highestDim = DIMENSIONS.find(function(d) { return d.key === highestKey; });
    const isFlat = s[highestKey] === s[lowestKey];
    const highPracticals = prac.filter(function(k) { return s[k] >= 65; }).map(function(k) {
      return DIMENSIONS.find(function(d) { return d.key === k; }).name;
    });

    const recoTitleEl = document.getElementById('recoTitle');
    if (recoTitleEl) {
      recoTitleEl.textContent = isFlat
        ? 'Every axis moves the needle — pick ' + lowestDim.name + ' first.'
        : 'Your constraint is ' + lowestDim.name + ' — not ' + highestDim.name + '.';
    }

    const body1El = document.getElementById('recoBody1');
    if (body1El) {
      const strengthStr = highPracticals.length
        ? highPracticals.join(' and ') + ' put you ahead of most practitioners.'
        : 'Your practitioner capital is still forming — every axis is a lever right now.';
      body1El.textContent = strengthStr + ' But ' + lowestDim.name + ' at ' + s[lowestKey] + ' is where the next 10x comes from in 2026. That\'s the gap worth closing first.';
    }

    const body2El = document.getElementById('recoBody2');
    if (body2El) {
      let orgNote;
      if (s.org >= 70) orgNote = "Your Org Readiness is high — the environment is ready for you to build. Permission isn't the blocker; your next move is.";
      else if (s.org >= 45) orgNote = "Org Readiness at " + s.org + " is neither blocking nor enabling. Enough runway to pilot something real without fighting governance.";
      else orgNote = "Org Readiness at " + s.org + " means the environment is working against you. Build your capital anyway — it's portable. Your next role will put it to work.";
      body2El.textContent = orgNote;
    }

    // Next steps
    const stepsEl = document.getElementById('nextSteps');
    if (stepsEl) {
      const steps = NEXT_STEPS[tier.name] || NEXT_STEPS.Builder;
      stepsEl.innerHTML = steps.map(function(step, i) {
        return '<div class="atr-step"><div class="atr-step-n">0' + (i + 1) + '</div><div>' + step + '</div></div>';
      }).join('');
    }

    // Gap insight — capability vs org readiness (always renders)
    var capAvg = Math.round((s.atlassian + s.automation + s.ai + s.influence) / 4);
    var gap = capAvg - s.org;
    var gapEl = document.getElementById('gapInsight');
    var giLabel = document.getElementById('gapLabel');
    var giBody = document.getElementById('gapBody');
    if (gapEl && giLabel && giBody) {
      gapEl.classList.remove('tone-ahead', 'tone-behind', 'tone-balanced');
      if (gap >= 15) {
        gapEl.classList.add('tone-ahead');
        giLabel.textContent = 'Skills Ahead';
        giBody.innerHTML = 'Your capability average is <strong>' + gap + ' points ahead</strong> of your org\'s readiness. You\'re not under-skilled — you\'re <strong>under-positioned</strong>. The move is visibility, not more courses.';
      } else if (gap <= -15) {
        gapEl.classList.add('tone-behind');
        giLabel.textContent = 'Org Ahead';
        giBody.innerHTML = 'Your org scores <strong>' + Math.abs(gap) + ' points above</strong> your capability average. The appetite is there; the gap is yours to close. <strong>Highest-urgency moment</strong> — ship something this quarter.';
      } else {
        gapEl.classList.add('tone-balanced');
        giLabel.textContent = 'In Step';
        giBody.innerHTML = 'You and your org are roughly <strong>in step</strong> — gap of ' + (gap >= 0 ? '+' : '') + gap + '. No positioning arbitrage to play. Your next move is pure capability: <strong>close the lowest practitioner axis first.</strong>';
      }
    }

    // Offer
    drawOffer(tier);
  }

  /* --- Offer --- */
  function drawOffer(tier) {
    const o = OFFERS[tier.name];
    if (!o) return;
    const el = document.getElementById('offer');
    if (!el) return;
    el.className = 'atr-offer ' + o.cls;

    var ctaHtml;
    if (o.waitlistForm || o.waitlistApi) {
      ctaHtml =
        '<form class="atr-waitlist-form" id="waitlistForm">' +
        '<label for="waitlistEmail" class="atr-sr-only">Email address</label>' +
        '<div class="atr-waitlist-row">' +
        '<input type="email" placeholder="you@company.com" required class="atr-waitlist-input" id="waitlistEmail" />' +
        '<button type="submit" class="atr-cta atr-cta-primary atr-waitlist-btn" id="waitlistBtn">' + o.cta + '</button>' +
        '</div>' +
        '<div class="atr-waitlist-fine">No spam. One note when founding seats open. Your spot is held.</div>' +
        '</form>';
    } else {
      ctaHtml =
        '<div class="atr-offer-row">' +
        '<a class="atr-cta atr-cta-primary" href="' + (o.url || '#b2bForm') + '"' + (o.url ? ' target="_blank" rel="noopener noreferrer"' : '') + '>' + o.cta + '</a>' +
        (o.price ? '<div class="atr-price"><strong>$' + o.price.dollars + '</strong> ' + o.price.cadence + '</div>' : '') +
        '</div>';
    }

    el.innerHTML =
      '<div class="atr-offer-eyebrow">' + o.eyebrow + '</div>' +
      '<h2 class="atr-offer-h2">' + o.h2 + '</h2>' +
      '<p class="atr-offer-pitch">' + o.pitch + '</p>' +
      '<ul class="atr-offer-list">' + o.bullets.map(function(b) { return '<li>' + b + '</li>'; }).join('') + '</ul>' +
      ctaHtml +
      '<div class="atr-aspiration"><strong>' + o.aspirationLabel + ':</strong> ' + o.aspiration + '</div>';

    if (o.waitlistForm || o.waitlistApi) {
      var wEmailEl = document.getElementById('waitlistEmail');
      if (wEmailEl && userEmail) {
        wEmailEl.value = userEmail;
      }
      var wForm = document.getElementById('waitlistForm');
      if (wForm) {
        wForm.addEventListener('submit', function(e) {
          e.preventDefault();
          var emailEl = document.getElementById('waitlistEmail');
          var btnEl = document.getElementById('waitlistBtn');
          var email = emailEl ? emailEl.value : '';
          if (!email) return;
          if (btnEl) { btnEl.textContent = 'Joining...'; btnEl.setAttribute('disabled', 'true'); }

          if (o.waitlistApi) {
            fetch('/api/waitlist/tag', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ email: email, first_name: firstName, tag: o.waitlistTag })
            }).then(function(res) {
              if (res.ok) {
                if (btnEl) { btnEl.textContent = "You're on the list!"; }
                if (emailEl) { emailEl.setAttribute('disabled', 'true'); }
              } else {
                if (btnEl) { btnEl.textContent = 'Something went wrong — try again'; btnEl.removeAttribute('disabled'); }
              }
            }).catch(function() {
              if (btnEl) { btnEl.textContent = "You're on the list!"; btnEl.setAttribute('disabled', 'true'); }
            });
          } else {
            var formData = new URLSearchParams();
            formData.append('email_address', email);
            if (firstName) formData.append('first_name', firstName);
            fetch('https://app.kit.com/forms/' + o.waitlistFormId + '/subscriptions', {
              method: 'POST',
              headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
              body: formData.toString(),
              redirect: 'manual'
            }).then(function(res) {
              if (res.ok || res.status === 302 || res.type === 'opaqueredirect') {
                if (btnEl) { btnEl.textContent = "You're on the list!"; }
                if (emailEl) { emailEl.setAttribute('disabled', 'true'); }
              } else {
                if (btnEl) { btnEl.textContent = 'Something went wrong — try again'; btnEl.removeAttribute('disabled'); }
              }
            }).catch(function() {
              if (btnEl) { btnEl.textContent = "You're on the list!"; btnEl.setAttribute('disabled', 'true'); }
            });
          }
        });
      }
    }
  }

  /* --- Particle scroll fade --- */
  (function() {
    const layer = document.getElementById('particlesLayer');
    if (!layer) return;
    const FADE_START = 80, FADE_END = 700;
    let ticking = false;
    function update() {
      const y = window.scrollY || 0;
      const t = Math.max(0, Math.min(1, (y - FADE_START) / (FADE_END - FADE_START)));
      layer.style.opacity = String(1 - t);
      ticking = false;
    }
    window.addEventListener('scroll', function() {
      if (!ticking) { requestAnimationFrame(update); ticking = true; }
    }, { passive: true });
    update();
  })();

  /* --- B2B waitlist form --- */
  var b2bEmailEl = document.getElementById('b2bEmail');
  if (b2bEmailEl && userEmail) { b2bEmailEl.value = userEmail; }
  const b2bForm = document.getElementById('b2bForm');
  if (b2bForm) {
    b2bForm.addEventListener('submit', function(e) {
      e.preventDefault();
      const emailEl = document.getElementById('b2bEmail');
      const btnEl = document.getElementById('b2bBtn');
      const email = emailEl ? emailEl.value : '';
      if (!email) return;
      fetch('/api/b2b-waitlist', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: email })
      }).then(function() {
        if (btnEl) { btnEl.textContent = "You're on the list →"; btnEl.setAttribute('disabled', 'true'); }
        if (emailEl) emailEl.value = '';
      }).catch(function() {
        if (btnEl) { btnEl.textContent = "You're on the list →"; btnEl.setAttribute('disabled', 'true'); }
      });
    });
  }

  /* --- Share buttons --- */
  var includeScoreEl = document.getElementById('includeScore');
  var previewEl = document.getElementById('sharePreview');

  var baseText = 'I just took the AgileTactix Agile-AI Readiness Assessment — find out where you stand on the curve.';

  function getShareText() {
    if (includeScoreEl && includeScoreEl.checked) {
      var tier = document.getElementById('tierName');
      var score = document.getElementById('totalScore');
      var tierName = tier ? tier.textContent : '';
      var scoreVal = score ? score.textContent : '';
      return 'I scored ' + scoreVal + '/100 (' + tierName + ') on the AgileTactix Agile-AI Readiness Assessment — find out where you stand on the curve.';
    }
    return baseText;
  }

  var assessmentUrl = 'https://agiletactix.ai/assessment';

  if (includeScoreEl && previewEl) {
    includeScoreEl.addEventListener('change', function() {
      previewEl.textContent = '"' + getShareText() + '"';
    });
  }

  var linkedInBtn = document.getElementById('shareLinkedIn');
  if (linkedInBtn) {
    linkedInBtn.addEventListener('click', function(e) {
      e.preventDefault();
      window.open('https://www.linkedin.com/sharing/share-offsite/?url=' + encodeURIComponent(assessmentUrl), '_blank', 'width=600,height=500');
    });
  }

  var copyBtn = document.getElementById('copyLink');
  if (copyBtn) {
    copyBtn.addEventListener('click', function(e) {
      e.preventDefault();
      var urlToCopy = assessmentUrl;
      navigator.clipboard.writeText(getShareText() + ' ' + urlToCopy).then(function() {
        copyBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> Copied!';
        setTimeout(function() {
          copyBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg> Copy link';
        }, 2000);
      });
    });
  }

  /* --- Run all --- */
  drawRadar(scores);
  drawBreakdown(scores);
  drawVerdict(scores);
}
</script>

<style is:global>
/* Results page — fully dark, isolated styles (global because JS generates most DOM) */
body {
  background: var(--at-black);
  color: var(--fg-1);
  font-family: Inter, -apple-system, BlinkMacSystemFont, sans-serif;
  min-height: 100vh;
}

.atr-skip-link {
  position: absolute;
  left: 1rem;
  top: 1rem;
  z-index: 9999;
  padding: 0.5rem 1rem;
  border-radius: 4px;
  background: #294bf3;
  color: #fff;
  font-weight: 600;
  text-decoration: none;
  transform: translateY(-200%);
  transition: transform 0.2s;
}
.atr-skip-link:focus {
  transform: translateY(0);
}

.atr-sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

/* Particles */
.atr-particles-layer {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
  transition: opacity 200ms linear;
  will-change: opacity;
}
.atr-particles-layer::before {
  content: '';
  position: absolute;
  inset: 0;
  background: var(--grad-hero-mesh);
  opacity: 0.55;
}
.atr-particles-layer canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  display: block;
}
.atr-vignette {
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at center, transparent 45%, rgba(10,10,10,0.75) 100%);
}

/* Page container */
.atr-page {
  position: relative;
  z-index: 1;
  max-width: 1200px;
  margin: 0 auto;
  padding: 64px 48px 96px;
}
@media (max-width: 768px) { .atr-page { padding: 40px 24px 64px; } }

/* Top bar */
.atr-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 56px;
}
.atr-logo-link { display: block; }
.atr-logo { height: 32px; width: auto; }
.atr-crumb {
  font-family: var(--font-mono);
