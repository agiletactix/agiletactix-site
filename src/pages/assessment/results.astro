}
.atr-reco-head { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
.atr-pill {
  display: inline-flex;
  align-items: center;
  padding: 6px 12px;
  background: rgba(37,99,235,0.18);
  border: 1px solid var(--border-blue);
  border-radius: 999px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--at-blue-300);
}
.atr-reco-h2 { font-size: 32px; font-weight: 800; letter-spacing: -0.02em; line-height: 1.15; margin-bottom: 16px; text-wrap: balance; }
.atr-reco-p { font-size: 16px; color: var(--fg-2); line-height: 1.65; margin-bottom: 20px; max-width: 720px; }
.atr-reco-p:last-of-type { margin-bottom: 0; }
.atr-reco p.reco-lede {
  font-size: 19px; line-height: 1.55; color: var(--fg-1);
  font-weight: 500; letter-spacing: -0.005em;
  padding-left: 18px; border-left: 3px solid var(--at-blue-400);
