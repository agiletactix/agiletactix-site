---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AudioPlayer from '../../components/podcast/AudioPlayer.astro';

export async function getStaticPaths() {
  const podcastEntries = await getCollection('podcast');
  return podcastEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'podcast'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { title, description, pubDate, duration, audioUrl, episodeNumber, episodeType, tags } = entry.data;
const label = episodeNumber ? `Episode ${episodeNumber}` : episodeType === 'trailer' ? 'Trailer' : 'Bonus';
---

<BaseLayout title={`${title} | Career Optional`} description={description}>
  <style is:global>
    #main-nav {
      position: relative !important;
      background-color: #0a1628 !important;
    }
    #main-nav + div {
      display: none !important;
    }
    .podcast-prose h2 {
      font-size: 1.75rem !important;
      line-height: 1.3 !important;
      margin-top: 2.5rem !important;
      margin-bottom: 1rem !important;
    }
    .podcast-prose h3 {
      font-size: 1.375rem !important;
      line-height: 1.4 !important;
      margin-top: 2rem !important;
      margin-bottom: 0.75rem !important;
    }
    .podcast-prose p {
      margin-bottom: 1.75rem !important;
    }
    @media (min-width: 640px) {
      .podcast-prose h2 {
        font-size: 2rem !important;
      }
      .podcast-prose h3 {
        font-size: 1.5rem !important;
      }
    }
  </style>

  <!-- Dark Header Section -->
  <section class="bg-[#0a1628] relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="mask-image: linear-gradient(to bottom, transparent 0%, rgba(0,0,0,0.2) 30%, rgba(0,0,0,0.5) 70%, rgba(0,0,0,0.8) 100%); -webkit-mask-image: linear-gradient(to bottom, transparent 0%, rgba(0,0,0,0.2) 30%, rgba(0,0,0,0.5) 70%, rgba(0,0,0,0.8) 100%);">
      <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
        <defs>
          <filter id="ep-glow" x="-50%" y="-50%" width="200%" height="200%">
            <feGaussianBlur stdDeviation="2" result="blur"/>
            <feMerge>
              <feMergeNode in="blur"/>
              <feMergeNode in="SourceGraphic"/>
            </feMerge>
          </filter>
        </defs>
        <g stroke="rgba(41, 75, 243, 0.12)" stroke-width="0.5" fill="none">
          <line x1="5%" y1="15%" x2="12%" y2="25%" />
          <line x1="82%" y1="10%" x2="90%" y2="20%" />
        </g>
        <g stroke="rgba(41, 75, 243, 0.25)" stroke-width="1" fill="none">
          <line x1="8%" y1="20%" x2="18%" y2="30%" />
          <line x1="75%" y1="15%" x2="85%" y2="25%" />
        </g>
        <g fill="rgba(41, 75, 243, 0.3)">
          <circle cx="8%" cy="20%" r="2" />
          <circle cx="18%" cy="30%" r="2.5" />
          <circle cx="75%" cy="15%" r="2" />
          <circle cx="85%" cy="25%" r="2.5" />
        </g>
        <g fill="rgba(41, 75, 243, 0.5)" filter="url(#ep-glow)">
          <circle cx="12%" cy="50%" r="3" />
          <circle cx="92%" cy="45%" r="3.5" />
        </g>
      </svg>
    </div>

    <div class="relative z-10 max-w-4xl mx-auto px-6 sm:px-8 py-16 sm:py-20">
      <!-- Breadcrumb -->
      <nav class="mb-8">
        <ol class="flex items-center space-x-2 text-sm text-gray-400">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" /></svg></li>
          <li><a href="/podcast" class="text-gray-300 font-medium hover:text-white transition-colors">Podcast</a></li>
        </ol>
      </nav>

      {tags && tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-6">
          {tags.map((tag) => (
            <span class="inline-block bg-primary-600/20 border border-primary-500/30 text-primary-300 text-xs font-semibold px-3 py-1 rounded-full">
              {tag}
            </span>
          ))}
        </div>
      )}

      <span class="text-primary-400 text-sm font-bold uppercase tracking-wider">{label} · Season 1</span>
      <h1 class="text-4xl sm:text-5xl font-bold text-white tracking-tight mb-6 mt-2">
        {title}
      </h1>

      <div class="flex items-center space-x-4 text-gray-400 mb-8">
        <div class="flex items-center space-x-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
          <span class="font-medium text-gray-300">Danny Liu</span>
        </div>
        <span class="text-gray-600">·</span>
        <time datetime={pubDate.toISOString()}>
          {new Date(pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <span class="text-gray-600">·</span>
        <span>{duration}</span>
      </div>

      <!-- Audio Player -->
      <AudioPlayer audioUrl={audioUrl} title={title} episodeNumber={episodeNumber} duration={duration} />
    </div>
  </section>

  <!-- Show Notes -->
  <article class="bg-white">
    <div class="max-w-4xl mx-auto px-6 sm:px-8 py-16 sm:py-20">
      <div class="podcast-prose prose prose-lg max-w-none prose-headings:font-bold prose-headings:text-gray-900 prose-p:text-gray-700 prose-p:leading-relaxed prose-a:text-primary-600 prose-a:no-underline hover:prose-a:underline prose-strong:text-gray-900 prose-ul:text-gray-700 prose-ol:text-gray-700 prose-code:text-primary-600 prose-code:bg-primary-50 prose-code:px-1 prose-code:py-0.5 prose-code:rounded prose-code:font-mono">
        <Content />
      </div>

      <!-- CTA -->
      <div class="mt-16 pt-8 border-t-2 border-gray-200">
        <div class="bg-gradient-to-br from-primary-50 to-primary-100 rounded-2xl p-8 sm:p-12 text-center">
          <h3 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
            Found this episode helpful?
          </h3>
          <p class="text-lg text-gray-700 mb-6 max-w-2xl mx-auto">
            Get the free playbook — 5 AI prompts that prove you're more than a facilitator.
          </p>
          <a href="/blueprint" class="btn-primary text-lg px-10 py-4 inline-block">
            Download the Free Blueprint
          </a>
        </div>
      </div>

      <!-- Back to Podcast -->
      <div class="mt-12 text-center">
        <a href="/podcast" class="inline-flex items-center text-primary-600 font-semibold hover:text-primary-700 transition-colors">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
          </svg>
          Back to all episodes
        </a>
      </div>
    </div>
  </article>

  <!-- Schema.org Episode Markup -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "PodcastEpisode",
    "name": title,
    "description": description,
    "datePublished": pubDate.toISOString(),
    "duration": `PT${duration.replace(':', 'M')}S`,
    "associatedMedia": {
      "@type": "MediaObject",
      "contentUrl": audioUrl
    },
    "partOfSeries": {
      "@type": "PodcastSeries",
      "name": "Career Optional",
      "url": "https://agiletactix.ai/podcast"
    },
    "author": {
      "@type": "Person",
      "name": "Danny Liu"
    }
  })} />
</BaseLayout>
