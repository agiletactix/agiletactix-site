---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PodcastHero from '../../components/podcast/PodcastHero.astro';
import EpisodeCard from '../../components/podcast/EpisodeCard.astro';

const pageTitle = 'Career Optional Podcast';
const pageDescription = 'The skills that make employment optional. Story-driven episodes on agile methodology, AI automation, and career resilience. Hosted by Danny Liu.';

const episodes = (await getCollection('podcast'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <style is:global>
    #main-nav {
      position: relative !important;
      background-color: #0a1628 !important;
    }
    #main-nav + div {
      display: none !important;
    }
  </style>

  <PodcastHero />

  <!-- Episode List -->
  <section class="bg-gray-50 py-16 sm:py-20">
    <div class="section-container">
      <div class="grid lg:grid-cols-[1fr_320px] gap-12">
        <!-- Episode List -->
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-10">Episodes</h2>
          <div class="grid gap-6">
            {episodes.map((episode) => (
              <EpisodeCard
                title={episode.data.title}
                episodeNumber={episode.data.episodeNumber}
                description={episode.data.description}
                pubDate={episode.data.pubDate}
                duration={episode.data.duration}
                slug={episode.slug}
                episodeType={episode.data.episodeType}
              />
            ))}
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="lg:sticky lg:top-8 lg:self-start">
          <h2 class="text-3xl font-bold text-gray-900 mb-10">About the Show</h2>
          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <p class="text-sm text-gray-600 leading-relaxed mb-5">
              The skills that make employment optional. Story-driven episodes on agile methodology, AI automation, and career resilience.
            </p>
            <div class="flex items-center space-x-3 mb-5">
              <div class="w-10 h-10 bg-primary-100 rounded-full flex items-center justify-center">
                <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-gray-900">Danny Liu</p>
                <p class="text-xs text-gray-500">Host</p>
              </div>
            </div>

            <hr class="border-gray-200 mb-5" />

            <h3 class="text-sm font-bold text-gray-900 uppercase tracking-wider mb-4">Subscribe</h3>
            <div class="space-y-3">
              <a href="#" class="flex items-center space-x-3 text-sm text-gray-700 hover:text-primary-600 transition-colors">
                <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
                <span>Apple Podcasts</span>
              </a>
              <a href="#" class="flex items-center space-x-3 text-sm text-gray-700 hover:text-primary-600 transition-colors">
                <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
                <span>Spotify</span>
              </a>
              <a href="/podcast.xml" class="flex items-center space-x-3 text-sm text-gray-700 hover:text-primary-600 transition-colors">
                <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/></svg>
                <span>RSS Feed</span>
              </a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-white py-16 sm:py-20">
    <div class="section-container text-center">
      <div class="bg-gradient-to-br from-primary-50 to-primary-100 rounded-2xl p-8 sm:p-12 max-w-3xl mx-auto">
        <h3 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
          Start Building Career Optionality
        </h3>
        <p class="text-lg text-gray-700 mb-6 max-w-2xl mx-auto">
          Get the free playbook — 5 AI prompts that prove you're more than a facilitator.
        </p>
        <a href="/blueprint" class="btn-primary text-lg px-10 py-4 inline-block">
          Download the Free Blueprint
        </a>
      </div>
    </div>
  </section>

  <!-- Schema.org Podcast Markup -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "PodcastSeries",
    "name": "Career Optional",
    "description": pageDescription,
    "url": "https://agiletactix.ai/podcast",
    "author": {
      "@type": "Person",
      "name": "Danny Liu"
    },
    "publisher": {
      "@type": "Organization",
      "name": "AgileTactix"
    },
    "webFeed": "https://agiletactix.ai/podcast.xml"
  })} />
</BaseLayout>
