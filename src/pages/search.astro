---
import LandingLayout from '../layouts/LandingLayout.astro';

const pageTitle = 'Search Lessons';
const pageDescription = 'Search across all lesson transcripts to find exactly what you need.';
---

<LandingLayout title={pageTitle} description={pageDescription} lightHeader={true}>

  <section class="bg-gradient-to-b from-gray-50 to-white min-h-screen pt-28 pb-16 lg:pt-32 lg:pb-20 px-4">
    <div class="max-w-3xl mx-auto">

      <!-- Header -->
      <div class="text-center mb-10">
        <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900 tracking-tight mb-3" style="letter-spacing: -0.02em;">
          Search Lessons
        </h1>
        <p class="text-lg text-gray-600">
          Find specific topics, concepts, and timestamps across all lesson transcripts.
        </p>
      </div>

      <!-- Search input -->
      <div class="relative mb-10">
        <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
        </svg>
        <input
          id="search-input"
          type="text"
          class="w-full pl-12 pr-4 py-4 text-lg border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#294bf3]/30 focus:border-[#294bf3] placeholder-gray-400 bg-white shadow-sm"
          placeholder="Search for topics like &quot;value streams&quot; or &quot;governance&quot;..."
          autocomplete="off"
        />
        <div id="search-spinner" class="absolute right-4 top-1/2 -translate-y-1/2 hidden">
          <div class="w-5 h-5 border-2 border-gray-300 border-t-[#294bf3] rounded-full animate-spin"></div>
        </div>
      </div>

      <!-- Results container -->
      <div id="search-results" class="space-y-4">
        <!-- Populated by JS -->
      </div>

      <!-- Empty state: initial -->
      <div id="search-empty" class="text-center py-12">
        <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
        </svg>
        <p class="text-gray-400 text-base">Type a search query to find topics across lesson transcripts</p>
      </div>

      <!-- No results state -->
      <div id="search-no-results" class="text-center py-12 hidden">
        <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.182 16.318A4.486 4.486 0 0012.016 15a4.486 4.486 0 00-3.198 1.318M21 12a9 9 0 11-18 0 9 9 0 0118 0zM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75zm-.375 0h.008v.015h-.008V9.75zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75zm-.375 0h.008v.015h-.008V9.75z" />
        </svg>
        <p class="text-gray-500 text-base mb-4">No matches found</p>
        <p class="text-gray-400 text-sm mb-6">Try different keywords or check your spelling</p>
        <a
          href="/rovo/assessment"
          class="inline-flex items-center justify-center px-6 py-3 rounded-xl bg-[#294bf3] text-white font-semibold text-sm hover:bg-[#1e3ad4] transition-colors"
        >
          Try the Assessment Instead
        </a>
      </div>

    </div>
  </section>

</LandingLayout>

<script is:inline>
(function () {
  var input = document.getElementById('search-input');
  var resultsContainer = document.getElementById('search-results');
  var emptyState = document.getElementById('search-empty');
  var noResults = document.getElementById('search-no-results');
  var spinner = document.getElementById('search-spinner');
  var debounceTimer = null;

  if (!input || !resultsContainer) return;

  // Read query from URL on page load
  var params = new URLSearchParams(window.location.search);
  var initialQuery = params.get('q');
  if (initialQuery) {
    input.value = initialQuery;
    performSearch(initialQuery);
  }

  input.addEventListener('input', function () {
    var query = input.value.trim();
    if (debounceTimer) clearTimeout(debounceTimer);

    if (query.length < 2) {
      resultsContainer.innerHTML = '';
      emptyState.classList.remove('hidden');
      noResults.classList.add('hidden');
      return;
    }

    debounceTimer = setTimeout(function () {
      performSearch(query);
    }, 300);
  });

  function performSearch(query) {
    spinner.classList.remove('hidden');
    emptyState.classList.add('hidden');
    noResults.classList.add('hidden');

    // Update URL without reload
    var url = new URL(window.location);
    url.searchParams.set('q', query);
    history.replaceState(null, '', url.toString());

    fetch('/api/search?q=' + encodeURIComponent(query))
      .then(function (res) { return res.json(); })
      .then(function (data) {
        spinner.classList.add('hidden');

        if (!data.results || data.results.length === 0) {
          resultsContainer.innerHTML = '';
          noResults.classList.remove('hidden');
          return;
        }

        resultsContainer.innerHTML = data.results.map(function (r) {
          var timestampStr = '';
          var timestampParam = '';
          if (r.timestamp !== null && r.timestamp !== undefined) {
            var m = Math.floor(r.timestamp / 60);
            var s = Math.floor(r.timestamp % 60);
            timestampStr = '<span class="inline-flex items-center gap-1 text-xs text-[#294bf3] font-mono">' +
              '<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>' +
              m + ':' + (s < 10 ? '0' : '') + s +
              '</span>';
            timestampParam = '?t=' + Math.floor(r.timestamp);
          }

          return '<a href="/member/lessons/' + r.lessonSlug + timestampParam + '" class="block bg-white rounded-xl border border-gray-200 p-5 hover:border-[#294bf3]/30 hover:shadow-sm transition-all">' +
            '<div class="flex items-start justify-between gap-3 mb-2">' +
            '<h3 class="text-base font-semibold text-gray-900">' + escapeHtml(r.lessonTitle) + '</h3>' +
            timestampStr +
            '</div>' +
            '<p class="text-sm text-gray-500 mb-1.5">Path: ' + escapeHtml(r.pathSlug) + '</p>' +
            '<p class="text-sm text-gray-600 leading-relaxed">' + r.excerpt + '</p>' +
            '</a>';
        }).join('');
      })
      .catch(function () {
        spinner.classList.add('hidden');
        resultsContainer.innerHTML = '<p class="text-red-500 text-sm text-center py-4">Search failed. Please try again.</p>';
      });
  }

  function escapeHtml(str) {
    var div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }
})();
</script>
