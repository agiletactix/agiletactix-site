---
import LandingLayout from '../layouts/LandingLayout.astro';

const pageTitle = 'Sign In';
const pageDescription = 'Sign in to your AgileTactix member account.';

// Pre-fill email from query param (e.g., from assessment result CTA)
const emailParam = Astro.url.searchParams.get('email') || '';
const returnTo = Astro.url.searchParams.get('returnTo') || '/member/dashboard';

export const prerender = false;
---

<LandingLayout title={pageTitle} description={pageDescription} lightHeader={true} noIndex={true}>
  <section class="bg-gradient-to-b from-gray-50 to-white min-h-screen pt-28 pb-16 lg:pt-32 lg:pb-20 px-4">
    <div class="max-w-md mx-auto">

      <!-- Auth Card -->
      <div class="bg-white rounded-2xl shadow-medium p-8 sm:p-10 border border-gray-100">

        <div class="text-center mb-8">
          <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 tracking-tight" style="letter-spacing: -0.02em;">
            Welcome back
          </h1>
          <p class="text-base text-gray-500 mt-2">Sign in to your AgileTactix account</p>
        </div>

        <!-- Google OAuth -->
        <button
          id="google-btn"
          type="button"
          class="w-full flex items-center justify-center gap-3 px-4 py-3 bg-white border-2 border-gray-200 rounded-xl text-base font-semibold text-gray-700 hover:bg-gray-50 hover:border-gray-300 transition-all duration-200 focus:outline-none focus:ring-4 focus:ring-primary-500/20"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          Continue with Google
        </button>

        <!-- Divider -->
        <div class="relative my-8">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-gray-200"></div>
          </div>
          <div class="relative flex justify-center">
            <span class="bg-white px-4 text-sm text-gray-400 uppercase tracking-wider">or</span>
          </div>
        </div>

        <!-- Email + Password Form -->
        <form id="login-form" class="space-y-5">
          <input type="hidden" name="returnTo" value={returnTo} />

          <div>
            <label for="email" class="block text-sm font-semibold text-gray-700 mb-1.5">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              value={emailParam}
              class="auth-input"
              placeholder="you@example.com"
              autocomplete="email"
            />
          </div>

          <div>
            <label for="password" class="block text-sm font-semibold text-gray-700 mb-1.5">Password</label>
            <input
              type="password"
              id="password"
              name="password"
              required
              class="auth-input"
              placeholder="Your password"
              autocomplete="current-password"
              minlength="8"
            />
          </div>

          <div class="flex items-center justify-end">
            <a href="/forgot-password" class="text-sm text-primary-600 hover:text-primary-800 hover:underline underline-offset-2 transition-colors">
              Forgot password?
            </a>
          </div>

          <!-- Error message -->
          <div id="error-msg" class="hidden text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-4 py-3"></div>

          <button
            type="submit"
            id="submit-btn"
            class="w-full btn-primary text-base py-3.5"
          >
            <span class="relative z-10">Sign in</span>
          </button>
        </form>

        <!-- Toggle to signup -->
        <p class="text-center text-sm text-gray-500 mt-8">
          Don't have an account?
          <a href={`/signup${emailParam ? `?email=${encodeURIComponent(emailParam)}` : ''}`} class="font-semibold text-primary-600 hover:text-primary-800 hover:underline underline-offset-2 transition-colors">
            Create one
          </a>
        </p>

      </div>
    </div>
  </section>
</LandingLayout>

<style>
  .auth-input {
    width: 100%;
    padding: 0.75rem 1rem;
    background-color: #f9fafb;
    border: 2px solid #e5e7eb;
    border-radius: 0.75rem;
    font-size: 1rem;
    line-height: 1.5;
    color: #111827;
    transition: border-color 0.15s ease, background-color 0.15s ease;
  }

  .auth-input::placeholder {
    color: #9ca3af;
  }

  .auth-input:focus {
    outline: none;
    border-color: #294bf3;
    background-color: #ffffff;
    box-shadow: 0 0 0 3px rgba(41, 75, 243, 0.1);
  }
</style>

<script is:inline>
  const form = document.getElementById('login-form');
  const errorMsg = document.getElementById('error-msg');
  const submitBtn = document.getElementById('submit-btn');
  const googleBtn = document.getElementById('google-btn');

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (errorMsg) errorMsg.classList.add('hidden');
      if (submitBtn) {
        submitBtn.setAttribute('disabled', 'true');
        submitBtn.innerHTML = '<span class="relative z-10">Signing in...</span>';
      }

      const formData = new FormData(form);
      const email = formData.get('email');
      const password = formData.get('password');
      const returnTo = formData.get('returnTo') || '/member/dashboard';

      try {
        const res = await fetch('/api/auth/sign-in/email', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, password }),
        });

        if (res.ok) {
          window.location.href = returnTo;
        } else {
          const data = await res.json().catch(() => ({}));
          const msg = data.message || 'Invalid email or password. Please try again.';
          if (errorMsg) {
            errorMsg.textContent = msg;
            errorMsg.classList.remove('hidden');
          }
        }
      } catch {
        if (errorMsg) {
          errorMsg.textContent = 'Something went wrong. Please try again.';
          errorMsg.classList.remove('hidden');
        }
      } finally {
        if (submitBtn) {
          submitBtn.removeAttribute('disabled');
          submitBtn.innerHTML = '<span class="relative z-10">Sign in</span>';
        }
      }
    });
  }

  if (googleBtn) {
    googleBtn.addEventListener('click', () => {
      window.location.href = '/api/auth/sign-in/social?provider=google';
    });
  }
</script>
