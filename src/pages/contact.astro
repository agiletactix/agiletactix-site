---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = 'Contact';
const pageDescription = 'Get in touch with AgileTactix. Whether you have questions about training, want to discuss custom solutions, or just want to connect—we\'d love to hear from you.';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-gray-50 via-white to-primary-50">
    <div class="section-container py-16 sm:py-20">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="heading-xl text-gray-900 mb-6">
          Get In Touch
        </h1>
        <p class="text-xl text-gray-600">
          Questions about training? Interested in enterprise delivery automation consulting? Just want to connect? Let's talk.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Form Section -->
  <section class="bg-white">
    <div class="section-container py-16 sm:py-20">
      <div class="max-w-2xl mx-auto">
        <h2 class="heading-md text-gray-900 mb-8">Tell me about your situation</h2>
        <form id="contact-lead-form" class="space-y-5">
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label for="first_name" class="block text-sm font-semibold text-gray-700 mb-2">First name *</label>
              <input type="text" id="first_name" name="first_name" required placeholder="First name"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all duration-200" />
            </div>
            <div>
              <label for="last_name" class="block text-sm font-semibold text-gray-700 mb-2">Last name</label>
              <input type="text" id="last_name" name="last_name" placeholder="Last name"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all duration-200" />
            </div>
          </div>
          <div>
            <label for="email_address" class="block text-sm font-semibold text-gray-700 mb-2">Email *</label>
            <input type="email" id="email_address" name="email_address" required placeholder="your.email@company.com"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all duration-200" />
          </div>
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label for="company" class="block text-sm font-semibold text-gray-700 mb-2">Company</label>
              <input type="text" id="company" name="fields[company]" placeholder="Company name"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all duration-200" />
            </div>
            <div>
              <label for="role" class="block text-sm font-semibold text-gray-700 mb-2">Your role</label>
              <input type="text" id="role" name="fields[role]" placeholder="e.g. VP Engineering"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all duration-200" />
            </div>
          </div>
          <div>
            <label for="pain_point" class="block text-sm font-semibold text-gray-700 mb-2">What's your biggest delivery challenge?</label>
            <textarea id="pain_point" name="fields[pain_point]" rows="4" placeholder="e.g. Manual sprint reporting across 12 teams, no automation in Jira"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all duration-200 resize-none"></textarea>
          </div>
          <button type="submit" class="w-full btn-primary text-lg py-4">Send Message</button>
          <p class="text-sm text-gray-500 text-center">I'll respond within 24 hours</p>
        </form>
        <div id="contact-success" class="hidden mt-6 text-center"><p class="text-green-600 text-lg font-semibold mb-4">Thanks! I'll review what you shared within 24 hours.</p><a href="https://calendly.com/dannyjliu/30min" target="_blank" rel="noopener" class="inline-block bg-primary-600 text-white px-8 py-3 rounded-lg font-bold text-base hover:bg-primary-700 transition-all">Book your discovery call now →</a></div>
        <p id="contact-error" class="text-red-600 font-medium mt-4 hidden text-center">Something went wrong. Please try again.</p>
      </div>

      <script is:inline>
        document.getElementById('contact-lead-form').addEventListener('submit', function(e) {
          e.preventDefault();
          var form = this;
          var btn = form.querySelector('button');
          var data = new URLSearchParams(new FormData(form)).toString();
          btn.textContent = 'Sending...';
          btn.disabled = true;

          if (window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1') {
        form.classList.add('hidden');
        document.getElementById('contact-success').classList.remove('hidden');
        return;
      }
      fetch('https://app.kit.com/forms/9228885/subscriptions', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: data,
            redirect: 'manual'
          }).then(function(res) {
            if (res.ok || res.status === 302 || res.type === 'opaqueredirect') {
              form.classList.add('hidden');
              document.getElementById('contact-success').classList.remove('hidden');
            } else {
              document.getElementById('contact-error').classList.remove('hidden');
              btn.textContent = 'Send Message';
              btn.disabled = false;
            }
          }).catch(function() {
            document.getElementById('contact-error').classList.remove('hidden');
            btn.textContent = 'Send Message';
            btn.disabled = false;
          });
        });
      </script>
    </div>
  </section>

  <!-- Alternative Contact Methods -->
  <section class="bg-gray-50">
    <div class="section-container py-16">
      <div class="max-w-3xl mx-auto">
        <h2 class="heading-md text-gray-900 text-center mb-12">
          Other Ways to Connect
        </h2>

        <div class="grid sm:grid-cols-2 gap-8 max-w-lg mx-auto">
          <!-- LinkedIn -->
          <div class="text-center">
            <div class="w-14 h-14 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-7 h-7 text-primary-600" fill="currentColor" viewBox="0 0 24 24">
                <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 mb-2">LinkedIn</h3>
            <a href="https://www.linkedin.com/in/dannyjliu/" class="text-primary-600 hover:text-primary-700">
              Connect on LinkedIn
            </a>
          </div>

          <!-- Twitter/X -->
          <div class="text-center">
            <div class="w-14 h-14 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-7 h-7 text-primary-600" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 mb-2">X</h3>
            <a href="https://x.com/dannyjliu" class="text-primary-600 hover:text-primary-700">
              Follow on X
            </a>
          </div>
        </div>

        <!-- Office Hours Note -->
        <div class="mt-12 bg-white rounded-xl p-8 shadow-soft text-center">
          <h3 class="text-xl font-semibold text-gray-900 mb-3">
            Office Hours
          </h3>
          <p class="text-gray-600">
            Available Monday - Friday, 9am - 5pm EST
          </p>
          <p class="text-sm text-gray-500 mt-2">
            Usually respond to all inquiries within 24 hours
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-primary-600 text-white">
    <div class="section-container py-16 sm:py-20">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="heading-lg mb-4">
          Or Skip the Form and Get the Blueprint Instead
        </h2>
        <p class="text-xl mb-8 text-primary-100">
          Download the free Agile-AI Blueprint and start your transformation today
        </p>
        <a href="/blueprint" class="inline-block bg-white text-primary-600 px-10 py-4 rounded-lg font-bold text-lg shadow-strong hover:shadow-xl hover:bg-gray-50 transform hover:-translate-y-1 transition-all duration-200">
          Get the Blueprint
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
