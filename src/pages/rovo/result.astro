---
import LandingLayout from '../../layouts/LandingLayout.astro';
import { TIER_META, type Tier, type Constraint } from '../../lib/rovo/scoring';

// Read query params set by the assessment form on submit
const tierParam = (Astro.url.searchParams.get('tier') || 'facilitator') as Tier;
const constraintParam = (Astro.url.searchParams.get('constraint') || 'flat') as Constraint;
const emailParam = Astro.url.searchParams.get('email') || '';

// Normalize to safe defaults
const validTiers: Tier[] = ['facilitator', 'builder', 'orchestrator'];
const validConstraints: Constraint[] = ['atlassian_depth', 'automation_output', 'ai_fluency', 'influence_range', 'flat'];
const tier: Tier = validTiers.includes(tierParam) ? tierParam : 'facilitator';
const constraint: Constraint = validConstraints.includes(constraintParam) ? constraintParam : 'flat';

const tierMeta = TIER_META[tier];

// --- Tier verdict copy ---
const tierVerdict: Record<Tier, string> = {
  facilitator: "You know Jira well enough to get by — but you've never built a rule that fires when a ticket moves, never queried a JQL filter to surface patterns, never configured a workflow that removes a step someone else has to do manually. That's not a skills gap. That's a decision you haven't made yet. The first automation rule you ship this week changes the category you're in.",
  builder: "You're shipping automations most practitioners have never seen in the wild — and you're doing it alone. That's the trap: solo builders hit a ceiling not because they run out of ideas, but because there's no one to pressure-test the patterns, no one to hand a playbook to, no one compounding what you've built. The output is real. The flywheel isn't.",
  orchestrator: "You have agents running while you sleep, influence across more than one team, and a mental model of this field that most people in your org haven't reached yet. Which means you're also the only one who fully understands what you built, the only one who can debug it when it breaks, and the only one in the room who sees the next problem coming. Being the most advanced person in your org looks like a win. It's also a ceiling.",
};

// --- Danny's Take copy ---
const dannysTake: Record<Constraint, string> = {
  atlassian_depth: "Your AI Fluency is real — you can prompt, you understand agents, you've probably built something interesting outside Jira. But right now you're duct-taping external tools onto a stack you haven't fully configured from the inside. Practitioners who skip Atlassian depth build workarounds; practitioners who own it build leverage. The trap is assuming the stack is too complex to configure, so you route around it. It isn't. Spend 90 minutes this week on a JQL query that surfaces real pattern data in your backlog — that's the starting point, not a certification.",
  automation_output: "You know the stack. You understand AI well enough to know what's possible. And you've shipped almost nothing in 90 days. That gap between knowing and doing is where practitioner capital goes to die — not because you're lazy, but because knowing gives you the feeling of progress without requiring a commit. The trap is research mode: one more tool review, one more comparison, one more webinar. Pick the single most repetitive manual step in your current sprint cycle and build one rule that kills it. Ship it this week. The first one is the hardest.",
  ai_fluency: "You configure Jira well. You have influence — people listen when you recommend a process change. And you haven't connected AI to any of it. That's the most dangerous gap on this assessment, because you look current from the outside while the tooling gap widens underneath. The trap: watching demos and treating AI as someone else's problem until it shows up in a job description. It already has. Find one workflow you touch every week — status reporting, retrospective synthesis, ticket triage — and replace one manual step with a prompt or an agent this sprint. That's the gap closing.",
  influence_range: "You can build. You've got automations running, rules configured, possibly an agent or two doing actual work. And the practitioners two teams over have no idea any of it exists, which means what you've built has a ceiling of one team. Solo operators with no lever can't compound. The trap is assuming your work speaks for itself — it doesn't, not in organizations where the person who communicates the pattern gets the credit and the room. Pick one thing you've built and spec it as a shareable playbook this week. Not a presentation. A one-pager another practitioner can configure in an hour.",
  flat: "No single dimension is clearly your constraint — you're mid-range across all five, which looks balanced but isn't. It's actually where compound growth lives: a 10% improvement across Atlassian Depth, Automation Output, AI Fluency, Influence Range, and Org Readiness compounds faster than going deep on one axis while the others stall. The trap is looking for your weakest link and going all-in on it. Don't. Pick one small move per dimension this sprint — one JQL query, one automation rule, one prompt that replaces a manual step, one thing you show a teammate, one conversation about your org's AI policy. Five small moves. Four weeks. Check the delta.",
};

// --- Offer pitch data ---
interface OfferPitch {
  heading: string;
  price: string;
  body: string;
  ctaLabel: string;
  ctaHref: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}

const offerPitch: Record<Tier, OfferPitch> = {
  facilitator: {
    heading: "Your next move: Sprint Automation Guide",
    price: "$27 one-time",
    body: "The Sprint Automation Guide is your first move, not your last. It's not a course and there's no video to watch — it's 5 automation rules configured for the most common manual ceremony overhead: status updates that write themselves, blocker flags that fire automatically, sprint reviews that pull their own data. Each rule comes with the exact Jira configuration steps. Most practitioners get the first one running in under an hour. That's the point. One rule changes what tier you're in.",
    ctaLabel: "Get the Sprint Automation Guide — $27 →",
    ctaHref: "/labs",
  },
  builder: {
    heading: "Your next move: Labs + Community",
    price: "Labs $197 one-time · Community coming soon",
    body: "Labs is where the deep material lives — workflow patterns, agent configurations, integrations that solo builders spend weeks reverse-engineering on their own. The one-time access gets you the playbooks. The community (opening soon) gets you the practitioners doing the same thing at the same time, which is the part solo builders don't have. The flywheel problem isn't a motivation problem. It's a peer problem. Labs addresses one. The community addresses both.",
    ctaLabel: "Join Labs — $197 →",
    ctaHref: "/labs",
    secondaryLabel: "Join the community waitlist →",
    secondaryHref: "/assessment",
  },
  orchestrator: {
    heading: "Your next move: Orchestrator Cohort",
    price: "$297/mo · Application-gated · 15 seats",
    body: "The Orchestrator cohort is 12–15 practitioners at your level, quarterly intake, application-gated. You're not the most advanced person in this room — and that's the point. The format is peer exchange on live systems: what's working, what broke, what the next pattern is. No curriculum, no instructor. You already have the skills. What you don't have is a room where you're not the one explaining everything. Applications open quarterly. If you're reading this at the Orchestrator tier, you already know whether this is the right room.",
    ctaLabel: "Apply for the Orchestrator Cohort →",
    ctaHref: "/contact",
  },
};

const offer = offerPitch[tier];
const pageTitle = `${tierMeta.label} — Your Practitioner Identity Result`;
const pageDescription = 'Your personalized practitioner identity assessment result — tier, dimension breakdown, and your tailored next step.';
---

<LandingLayout title={pageTitle} description={pageDescription} lightHeader={true} noIndex={true}>
  <section class="bg-gradient-to-b from-gray-50 to-white min-h-screen pt-28 pb-16 lg:pt-32 lg:pb-20 px-4">
    <div class="max-w-3xl mx-auto">

      <!-- Tier badge -->
      <div class="inline-flex items-center gap-2 mb-6 text-sm uppercase tracking-widest font-bold">
        <span>{tierMeta.emoji}</span>
        <span class={tierMeta.color}>{tierMeta.label}</span>
      </div>

      <!-- Tier verdict -->
      <div class="bg-gray-50 border-l-4 border-[#294bf3] rounded-r-lg p-6 mb-10">
        <p class="text-lg text-gray-800 leading-relaxed italic">{tierVerdict[tier]}</p>
      </div>

      <!-- Radar chart -->
      <div class="my-10">
        <h2 class="text-lg font-bold text-gray-900 mb-4 text-center">Your Dimension Breakdown</h2>
        <div class="flex justify-center">
          <canvas id="radarChart" width="400" height="400" style="max-width: 400px;"></canvas>
        </div>
      </div>

      <!-- Danny's Take -->
      <div class="bg-white rounded-2xl p-6 lg:p-8 border border-gray-200 mb-10">
        <h2 class="text-lg font-bold text-gray-900 mb-4">Danny's Take</h2>
        <p class="text-base text-gray-700 leading-relaxed">{dannysTake[constraint]}</p>
      </div>

      <!-- Offer pitch card -->
      <div class="bg-[#0a1628] text-white rounded-2xl p-8 mb-10">
        <h2 class="text-xl font-bold text-white mb-2">{offer.heading}</h2>
        <p class="text-2xl font-extrabold text-[#294bf3] mb-4">{offer.price}</p>
        <p class="text-base text-gray-300 leading-relaxed mb-6">{offer.body}</p>
        <div class="flex flex-col sm:flex-row gap-4 items-start">
          <a
            href={offer.ctaHref}
            class="inline-block bg-[#294bf3] hover:bg-blue-700 text-white font-bold text-base px-8 py-4 rounded-lg transition-colors"
          >
            {offer.ctaLabel}
          </a>
          {offer.secondaryLabel && offer.secondaryHref && (
            <a
              href={offer.secondaryHref}
              class="text-base text-gray-300 hover:text-white hover:underline underline-offset-4 px-4 py-4 transition-colors"
            >
              {offer.secondaryLabel}
            </a>
          )}
        </div>
      </div>

      <!-- Save results -->
      <div class="bg-[#f0f7ff] border-l-4 border-[#294bf3] rounded-r-lg p-6 lg:p-8 mb-8">
        <h2 class="text-lg font-bold text-gray-900 mb-3">Save your results</h2>
        <p class="text-base text-gray-700 leading-relaxed mb-4">
          Create a free account to save your assessment results, track your progress over time, and unlock your personalized learning path.
        </p>
        <a
          href={`/signup${emailParam ? `?email=${encodeURIComponent(emailParam)}` : ''}`}
          class="btn-primary text-sm px-6 py-3 inline-block"
        >
          <span class="relative z-10">Create your free account</span>
        </a>
      </div>

      <!-- What happens next -->
      <div class="bg-white rounded-2xl p-6 lg:p-8 border border-gray-200 mb-8">
        <h2 class="text-lg font-bold text-gray-900 mb-3">What happens next</h2>
        <p class="text-base text-gray-700 leading-relaxed mb-3">
          A detailed results report is on its way to your inbox. It includes your dimension-by-dimension breakdown and specific actions for your next move.
        </p>
        <p class="text-sm text-gray-500">
          Didn't get it? Check spam / promotions. Still nothing in a few minutes? Email <a href="mailto:danny@agiletactix.com" class="text-primary-700 hover:underline">danny@agiletactix.com</a>.
        </p>
      </div>

      <!-- Back link -->
      <p class="text-center">
        <a href="/rovo" class="text-sm text-gray-500 hover:text-gray-900 hover:underline underline-offset-4 transition-colors">
          ← Back to the assessment overview
        </a>
      </p>

    </div>
  </section>

<script is:inline>
  function initRadarChart() {
    var canvas = document.getElementById('radarChart');
    if (!canvas) return;
    var p = new URLSearchParams(window.location.search);
    var data = [
      parseInt(p.get('d_atlassian_depth')   || '0'),
      parseInt(p.get('d_automation_output') || '0'),
      parseInt(p.get('d_ai_fluency')        || '0'),
      parseInt(p.get('d_influence_range')   || '0'),
      parseInt(p.get('d_org_readiness')     || '0'),
    ];
    new Chart(canvas.getContext('2d'), {
      type: 'radar',
      data: {
        labels: ['Atlassian Depth', 'Automation Output', 'AI Fluency', 'Influence Range', 'Org Readiness'],
        datasets: [{
          data: data,
          backgroundColor: 'rgba(41, 75, 243, 0.15)',
          borderColor: '#294bf3',
          pointBackgroundColor: '#294bf3',
          pointBorderColor: '#fff',
          pointHoverBackgroundColor: '#fff',
          pointHoverBorderColor: '#294bf3',
          borderWidth: 2,
        }]
      },
      options: {
        responsive: true,
        scales: {
          r: {
            min: 0,
            max: 100,
            ticks: { stepSize: 25, color: '#6b7280', font: { size: 11 } },
            grid: { color: 'rgba(0,0,0,0.08)' },
            angleLines: { color: 'rgba(0,0,0,0.08)' },
            pointLabels: { font: { size: 12, weight: '600' }, color: '#374151' },
          }
        },
        plugins: { legend: { display: false } }
      }
    });
  }

  if (typeof Chart !== 'undefined') {
    initRadarChart();
  } else {
    var s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js';
    s.onload = initRadarChart;
    document.head.appendChild(s);
  }
</script>

</LandingLayout>
