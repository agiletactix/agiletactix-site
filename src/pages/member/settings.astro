---
import LandingLayout from '../../layouts/LandingLayout.astro';

export const prerender = false;

// User + session are set by middleware (src/middleware.ts)
const user = (Astro.locals as Record<string, unknown>).user as {
  id: string;
  name: string;
  email: string;
  createdAt?: string;
} | undefined;

// Safety: middleware should have redirected, but guard anyway
if (!user) {
  return Astro.redirect('/login', 302);
}

const memberSince = user.createdAt
  ? new Date(user.createdAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })
  : null;

const pageTitle = 'Account Settings';
const pageDescription = 'Manage your AgileTactix account settings.';
---

<LandingLayout title={pageTitle} description={pageDescription} lightHeader={true} noIndex={true}>
  <section class="bg-gradient-to-b from-gray-50 to-white min-h-screen pt-28 pb-16 lg:pt-32 lg:pb-20 px-4">
    <div class="max-w-2xl mx-auto">

      <!-- Back to dashboard -->
      <a href="/member/dashboard" class="inline-flex items-center text-sm text-gray-500 hover:text-gray-900 transition-colors mb-6">
        <svg class="w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        Back to Dashboard
      </a>

      <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900 tracking-tight mb-8" style="letter-spacing: -0.02em;">
        Account Settings
      </h1>

      <!-- ═══ Account Info ═══ -->
      <div class="bg-white rounded-2xl p-6 lg:p-8 border border-gray-200 shadow-sm mb-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">Account Information</h2>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-500 mb-1">Name</label>
            <p class="text-base text-gray-900">{user.name || 'Not set'}</p>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-500 mb-1">Email</label>
            <p class="text-base text-gray-900">{user.email}</p>
          </div>
          {memberSince && (
            <div>
              <label class="block text-sm font-medium text-gray-500 mb-1">Member since</label>
              <p class="text-base text-gray-900">{memberSince}</p>
            </div>
          )}
        </div>
      </div>

      <!-- ═══ Change Password ═══ -->
      <div class="bg-white rounded-2xl p-6 lg:p-8 border border-gray-200 shadow-sm mb-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">Change Password</h2>
        <form id="password-form" class="space-y-4">
          <div>
            <label for="current-password" class="block text-sm font-medium text-gray-700 mb-1">Current password</label>
            <input
              type="password"
              id="current-password"
              name="currentPassword"
              autocomplete="current-password"
              class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm text-gray-900 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors"
              required
            />
          </div>
          <div>
            <label for="new-password" class="block text-sm font-medium text-gray-700 mb-1">New password</label>
            <input
              type="password"
              id="new-password"
              name="newPassword"
              autocomplete="new-password"
              minlength="8"
              class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm text-gray-900 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors"
              required
            />
            <p class="text-xs text-gray-400 mt-1">Minimum 8 characters</p>
          </div>
          <div id="password-message" class="hidden text-sm rounded-lg px-4 py-2.5"></div>
          <button
            type="submit"
            class="btn-primary text-sm px-6 py-2.5 inline-block"
          >
            <span class="relative z-10">Update Password</span>
          </button>
        </form>
      </div>

      <!-- ═══ Sign Out ═══ -->
      <div class="bg-white rounded-2xl p-6 lg:p-8 border border-gray-200 shadow-sm mb-6">
        <h2 class="text-lg font-bold text-gray-900 mb-2">Sign Out</h2>
        <p class="text-sm text-gray-600 mb-4">Sign out of your account on this device.</p>
        <button
          id="signout-btn"
          class="inline-flex items-center px-5 py-2.5 rounded-lg text-sm font-semibold border border-gray-300 text-gray-700 hover:bg-gray-50 transition-colors"
        >
          <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15m3 0l3-3m0 0l-3-3m3 3H9" />
          </svg>
          Sign Out
        </button>
      </div>

      <!-- ═══ Danger Zone: Deactivate Account ═══ -->
      <div class="bg-white rounded-2xl p-6 lg:p-8 border border-red-200 shadow-sm">
        <h2 class="text-lg font-bold text-red-700 mb-2">Deactivate Account</h2>
        <p class="text-sm text-gray-600 mb-4">
          This will cancel any active subscription and deactivate your account. Your data will be retained but your account will be inaccessible. Contact <a href="mailto:danny@agiletactix.com" class="text-primary-700 hover:underline">danny@agiletactix.com</a> to reactivate.
        </p>
        <button
          id="deactivate-btn"
          class="inline-flex items-center px-5 py-2.5 rounded-lg text-sm font-semibold border border-red-300 text-red-700 hover:bg-red-50 transition-colors"
        >
          Deactivate my account
        </button>
        <div id="deactivate-confirm" class="hidden mt-4 p-4 bg-red-50 rounded-lg border border-red-200">
          <p class="text-sm text-red-800 mb-3">Are you sure? This action will cancel your subscription and deactivate your account.</p>
          <div class="flex gap-3">
            <button id="deactivate-confirm-btn" class="px-4 py-2 rounded-lg text-sm font-semibold bg-red-600 text-white hover:bg-red-700 transition-colors">
              Yes, deactivate
            </button>
            <button id="deactivate-cancel-btn" class="px-4 py-2 rounded-lg text-sm font-semibold border border-gray-300 text-gray-700 hover:bg-gray-50 transition-colors">
              Cancel
            </button>
          </div>
          <div id="deactivate-message" class="hidden text-sm mt-3 rounded-lg px-4 py-2.5"></div>
        </div>
      </div>

    </div>
  </section>
</LandingLayout>

<script is:inline>
  // ─── Sign out ──────────────────────────────────────────────────────
  var signoutBtn = document.getElementById('signout-btn');
  if (signoutBtn) {
    signoutBtn.addEventListener('click', async function() {
      try {
        await fetch('/api/auth/sign-out', { method: 'POST' });
      } catch (_e) { /* ignore */ }
      window.location.href = '/';
    });
  }

  // ─── Change password ───────────────────────────────────────────────
  var passwordForm = document.getElementById('password-form');
  if (passwordForm) {
    passwordForm.addEventListener('submit', async function(e) {
      e.preventDefault();
      var msg = document.getElementById('password-message');
      var currentPw = document.getElementById('current-password');
      var newPw = document.getElementById('new-password');
      if (!msg || !currentPw || !newPw) return;

      msg.className = 'hidden';

      try {
        var res = await fetch('/api/auth/change-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            currentPassword: currentPw.value,
            newPassword: newPw.value,
          }),
        });

        if (res.ok) {
          msg.textContent = 'Password updated successfully.';
          msg.className = 'text-sm rounded-lg px-4 py-2.5 bg-green-50 text-green-700 border border-green-200';
          currentPw.value = '';
          newPw.value = '';
        } else {
          var data = {};
          try { data = await res.json(); } catch (_e) { /* ignore */ }
          msg.textContent = data.message || 'Failed to update password. Please check your current password.';
          msg.className = 'text-sm rounded-lg px-4 py-2.5 bg-red-50 text-red-700 border border-red-200';
        }
      } catch (_err) {
        msg.textContent = 'An error occurred. Please try again.';
        msg.className = 'text-sm rounded-lg px-4 py-2.5 bg-red-50 text-red-700 border border-red-200';
      }
    });
  }

  // ─── Deactivate account ────────────────────────────────────────────
  var deactivateBtn = document.getElementById('deactivate-btn');
  var deactivateConfirm = document.getElementById('deactivate-confirm');
  var deactivateConfirmBtn = document.getElementById('deactivate-confirm-btn');
  var deactivateCancelBtn = document.getElementById('deactivate-cancel-btn');

  if (deactivateBtn && deactivateConfirm) {
    deactivateBtn.addEventListener('click', function() {
      deactivateConfirm.classList.remove('hidden');
      deactivateBtn.classList.add('hidden');
    });
  }

  if (deactivateCancelBtn && deactivateConfirm && deactivateBtn) {
    deactivateCancelBtn.addEventListener('click', function() {
      deactivateConfirm.classList.add('hidden');
      deactivateBtn.classList.remove('hidden');
    });
  }

  if (deactivateConfirmBtn) {
    deactivateConfirmBtn.addEventListener('click', async function() {
      var msg = document.getElementById('deactivate-message');
      if (!msg) return;

      try {
        var res = await fetch('/api/auth/delete-user', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
        });

        if (res.ok) {
          msg.textContent = 'Account deactivated. Redirecting...';
          msg.className = 'text-sm mt-3 rounded-lg px-4 py-2.5 bg-green-50 text-green-700 border border-green-200';
          setTimeout(function() { window.location.href = '/'; }, 2000);
        } else {
          msg.textContent = 'Failed to deactivate account. Please contact support.';
          msg.className = 'text-sm mt-3 rounded-lg px-4 py-2.5 bg-red-50 text-red-700 border border-red-200';
        }
      } catch (_err) {
        msg.textContent = 'An error occurred. Please try again.';
        msg.className = 'text-sm mt-3 rounded-lg px-4 py-2.5 bg-red-50 text-red-700 border border-red-200';
      }
    });
  }
</script>
