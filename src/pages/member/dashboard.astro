            <div class="space-y-3">
              {recentEvents.map((event) => (
                <div class="flex items-center justify-between py-2 border-b border-gray-100 last:border-0">
                  <span class="text-sm text-gray-700">
                    {eventLabels[event.eventType ?? ''] ?? event.eventType}
