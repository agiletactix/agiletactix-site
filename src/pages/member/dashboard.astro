</LandingLayout>

<script is:inline>
  // Sign out
  document.querySelectorAll('#signout-quick').forEach(function(btn) {
    btn.addEventListener('click', async function() {
      try {
        await fetch('/api/auth/sign-out', { method: 'POST' });
      } catch (_e) {
        // ignore
      }
      window.location.href = '/';
    });
  });

  // Stripe Checkout — Upgrade to Pro
  var upgradeBtn = document.getElementById('upgrade-membership');
  var reactivateBtn = document.getElementById('reactivate-membership');

  function handleProCheckout() {
    return async function() {
      var btn = this;
      btn.disabled = true;
      var origHTML = btn.innerHTML;
      btn.textContent = 'Redirecting...';

      try {
        var res = await fetch('/api/stripe/checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ priceType: 'pro' })
        });
        var data = await res.json();
        if (data.url) {
          window.location.href = data.url;
        } else {
          alert(data.error || 'Something went wrong. Please try again.');
          btn.disabled = false;
          btn.innerHTML = origHTML;
        }
      } catch (err) {
        alert('Network error. Please try again.');
        btn.disabled = false;
        btn.innerHTML = origHTML;
      }
    };
  }

  if (upgradeBtn) upgradeBtn.addEventListener('click', handleProCheckout());
  if (reactivateBtn) reactivateBtn.addEventListener('click', handleProCheckout());

  // Stripe Billing Portal — Manage subscription
  var manageBtn = document.getElementById('manage-subscription');
  if (manageBtn) {
    manageBtn.addEventListener('click', async function() {
      var btn = this;
      btn.disabled = true;
      var origHTML = btn.innerHTML;
      btn.textContent = 'Redirecting...';

      try {
        var res = await fetch('/api/stripe/portal', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' }
        });
        var data = await res.json();
        if (data.url) {
          window.location.href = data.url;
        } else {
          alert(data.error || 'Unable to open billing portal.');
          btn.disabled = false;
          btn.innerHTML = origHTML;
        }
      } catch (err) {
        alert('Network error. Please try again.');
        btn.disabled = false;
        btn.innerHTML = origHTML;
      }
    });
  }
</script>
