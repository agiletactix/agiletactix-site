---
import LandingLayout from '../../layouts/LandingLayout.astro';
import { getEnvFromLocals } from '../../lib/auth';
import { getDb, getMemberByEmail, getMemberByAuthUserId, getLatestAssessment, getLearningPath, getLessonProgress, getRecentEvents } from '../../lib/db/index';
import { TIER_META, dimensionLabel, type Tier, type DimensionScores } from '../../lib/rovo/scoring';
import { DIMENSIONS, type Dimension } from '../../lib/rovo/questions';
import { ALL_LESSONS } from '../../lib/rovo/learning-paths';

export const prerender = false;

// User + session are set by middleware (src/middleware.ts)
const user = (Astro.locals as Record<string, unknown>).user as {
  id: string;
  name: string;
  email: string;
  createdAt?: string;
} | undefined;

// Safety: middleware should have redirected, but guard anyway
if (!user) {
  return Astro.redirect('/login', 302);
}

const firstName = user.name ? user.name.split(' ')[0] : 'there';

// ─── Data loading with D1 fallback ───────────────────────────────────
type MemberRow = {
  id: string;
  email: string;
  firstName: string | null;
  role: string | null;
  deployment: string | null;
  tier: string | null;
  betterAuthUserId: string | null;
  stripeCustomerId: string | null;
  membershipStatus: string | null;
  createdAt: string | null;
  updatedAt: string | null;
};

type AssessmentRow = {
  id: string;
  memberId: string | null;
  overallScorePct: number | null;
  tier: string | null;
  dimensionScores: string | null;
  weakDimensions: string | null;
  deploymentOverride: number | null;
  completedAt: string | null;
};

type LearningPathRow = {
  id: string;
  memberId: string | null;
  pathSlug: string | null;
  assignedAt: string | null;
  completedAt: string | null;
};

type LessonProgressRow = {
  memberId: string | null;
  lessonId: string | null;
  status: string | null;
  startedAt: string | null;
  completedAt: string | null;
};

type EventRow = {
  id: string;
  memberId: string | null;
  eventType: string | null;
  metadata: string | null;
  createdAt: string | null;
};

let member: MemberRow | undefined = undefined;
let latestAssessment: AssessmentRow | undefined = undefined;
let learningPath: LearningPathRow | undefined = undefined;
let lessons: LessonProgressRow[] = [];
let recentEvents: EventRow[] = [];

try {
  const env = getEnvFromLocals(Astro.locals as Record<string, unknown>);
  if (env) {
    const db = getDb(env.DB);

    // Try by auth user ID first, fallback to email
    member = (await getMemberByAuthUserId(db, user.id)) ?? (await getMemberByEmail(db, user.email)) ?? undefined;

    if (member) {
      latestAssessment = (await getLatestAssessment(db, member.id)) ?? undefined;
      learningPath = (await getLearningPath(db, member.id)) ?? undefined;
      lessons = await getLessonProgress(db, member.id);
      recentEvents = await getRecentEvents(db, member.id, 5);
    }
  }
} catch (err) {
  console.error('[dashboard] D1 query failed:', err);
  // Graceful fallback — show placeholder content when D1 unavailable
}

// ─── Derived data ────────────────────────────────────────────────────
const memberSince = member?.createdAt
  ? new Date(member.createdAt).toLocaleDateString('en-US', { month: 'long', year: 'numeric' })
  : user.createdAt
    ? new Date(user.createdAt).toLocaleDateString('en-US', { month: 'long', year: 'numeric' })
    : null;

const membershipStatus = member?.membershipStatus ?? 'free';
const justUpgraded = Astro.url.searchParams.get('upgraded') === 'true';

// Assessment data
const assessmentTier = latestAssessment?.tier as Tier | undefined;
const assessmentScore = latestAssessment?.overallScorePct ?? 0;
const tierMeta = assessmentTier ? TIER_META[assessmentTier] : null;

let dimensionScores: Partial<DimensionScores> = {};
let weakDimensions: string[] = [];
if (latestAssessment?.dimensionScores) {
  try { dimensionScores = JSON.parse(latestAssessment.dimensionScores) as Partial<DimensionScores>; } catch { /* skip */ }
}
if (latestAssessment?.weakDimensions) {
  try { weakDimensions = JSON.parse(latestAssessment.weakDimensions) as string[]; } catch { /* skip */ }
}

// Learning path data
const pathSlug = learningPath?.pathSlug;
const pathNames: Record<string, string> = {
  'rovo-governance': 'Rovo Governance Path',
  'stack-optimizer': 'Close the Gap Path',
  'foundation-builder': 'Build the Foundation Path',
  'getting-started': 'Getting Started Path',
};
const pathName = pathSlug ? (pathNames[pathSlug] ?? pathSlug) : null;

// Calculate learning path progress
const totalLessons = lessons.length;
const completedLessons = lessons.filter(l => l.status === 'completed').length;
const pathProgress = totalLessons > 0 ? Math.round((completedLessons / totalLessons) * 100) : 0;
const nextLesson = lessons.find(l => l.status === 'in_progress') ?? lessons.find(l => l.status === 'not_started');

// Event type labels
const eventLabels: Record<string, string> = {
  assessment_completed: 'Completed assessment',
  lesson_started: 'Started lesson',
  lesson_completed: 'Completed lesson',
  login: 'Signed in',
  video_watched: 'Watched video',
};

function formatEventDate(dateStr: string | null): string {
  if (!dateStr) return '';
  const d = new Date(dateStr);
  const now = new Date();
  const diffMs = now.getTime() - d.getTime();
  const diffMins = Math.floor(diffMs / 60000);
  if (diffMins < 1) return 'Just now';
  if (diffMins < 60) return `${diffMins}m ago`;
  const diffHours = Math.floor(diffMins / 60);
  if (diffHours < 24) return `${diffHours}h ago`;
  const diffDays = Math.floor(diffHours / 24);
  if (diffDays < 7) return `${diffDays}d ago`;
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}

const dimensionKeys = Object.keys(DIMENSIONS) as Dimension[];

const pageTitle = 'Member Dashboard';
const pageDescription = 'Your AgileTactix member dashboard — assessment results, learning paths, and membership status.';
---

<LandingLayout title={pageTitle} description={pageDescription} lightHeader={true} noIndex={true}>
  <section class="bg-gradient-to-b from-gray-50 to-white min-h-screen pt-28 pb-16 lg:pt-32 lg:pb-20 px-4">
    <div class="max-w-5xl mx-auto">

      <!-- Welcome header -->
      <div class="mb-10">
        <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900 tracking-tight" style="letter-spacing: -0.02em;">
          Welcome back, {firstName}
        </h1>
        <p class="text-lg text-gray-500 mt-2">
          {user.email}{memberSince ? ` · Member since ${memberSince}` : ''}
        </p>
      </div>

      <!-- Upgrade success banner -->
      {justUpgraded && (
        <div class="mb-6 bg-green-50 border border-green-200 rounded-xl p-4 flex items-center gap-3" id="upgrade-banner">
          <svg class="w-5 h-5 text-green-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <p class="text-sm font-medium text-green-800">Welcome to Pro! Your membership is now active. Full learning paths and office hours are unlocked.</p>
        </div>
      )}

      <!-- Main dashboard grid -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">

        <!-- ═══ Assessment Score Card ═══ -->
        {latestAssessment && tierMeta ? (
          <div class="bg-white rounded-2xl p-6 lg:p-8 border border-gray-200 shadow-sm lg:col-span-2">
            <div class="flex items-center justify-between mb-6">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-primary-50 flex items-center justify-center">
                  <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" />
                  </svg>
                </div>
                <h2 class="text-lg font-bold text-gray-900">Rovo-Readiness Assessment</h2>
              </div>
              <a href="/rovo/assessment" class="text-sm font-semibold text-primary-600 hover:text-primary-800 transition-colors">
                Retake Assessment
              </a>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              <!-- Left: Tier + Overall Score -->
              <div>
                <!-- Tier badge -->
                <div class="inline-flex items-center gap-2 mb-4 px-4 py-2 rounded-full bg-gray-50 border border-gray-200">
                  <span class="text-lg">{tierMeta.emoji}</span>
                  <span class={`text-sm font-bold uppercase tracking-wider ${tierMeta.color}`}>{tierMeta.label}</span>
                </div>

                <!-- Overall score -->
                <div class="mb-4">
                  <div class="flex items-end gap-2 mb-2">
                    <span class="text-4xl font-extrabold text-gray-900">{assessmentScore}%</span>
                    <span class="text-sm text-gray-500 mb-1">overall readiness</span>
                  </div>
                  <div class="w-full bg-gray-100 rounded-full h-3">
                    <div
                      class="h-3 rounded-full transition-all duration-500"
                      style={`width: ${assessmentScore}%; background-color: ${assessmentScore >= 80 ? '#16a34a' : assessmentScore >= 65 ? '#ca8a04' : assessmentScore >= 40 ? '#ea580c' : '#dc2626'}`}
                    />
                  </div>
                </div>

                {latestAssessment.completedAt && (
                  <p class="text-xs text-gray-400">
                    Completed {new Date(latestAssessment.completedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </p>
                )}
              </div>

              <!-- Right: Dimension breakdown -->
              <div>
                <p class="text-sm font-semibold text-gray-700 mb-3 uppercase tracking-wider">Dimensions</p>
                <div class="space-y-3">
                  {dimensionKeys.map((dim) => {
                    const score = dimensionScores[dim] ?? 0;
                    const isWeak = weakDimensions.includes(dim);
                    return (
                      <div>
                        <div class="flex items-center justify-between mb-1">
                          <span class={`text-sm ${isWeak ? 'font-semibold text-orange-700' : 'text-gray-700'}`}>
                            {isWeak && <span class="text-orange-500 mr-1">!</span>}
                            {dimensionLabel(dim)}
                          </span>
                          <span class={`text-sm font-medium ${isWeak ? 'text-orange-700' : 'text-gray-500'}`}>{score}%</span>
                        </div>
                        <div class="w-full bg-gray-100 rounded-full h-2">
                          <div
                            class="h-2 rounded-full transition-all duration-500"
                            style={`width: ${score}%; background-color: ${isWeak ? '#ea580c' : '#294bf3'}`}
                          />
                        </div>
                      </div>
                    );
                  })}
                </div>
                {weakDimensions.length > 0 && (
                  <p class="text-xs text-orange-600 mt-3">
                    {weakDimensions.length === 1 ? '1 dimension' : `${weakDimensions.length} dimensions`} below 60% threshold
                  </p>
                )}
              </div>
            </div>
          </div>
        ) : (
          <!-- No assessment — CTA card -->
          <div class="bg-white rounded-2xl p-6 lg:p-8 border border-gray-200 shadow-sm lg:col-span-2">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-xl bg-primary-50 flex items-center justify-center">
                <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" />
                </svg>
              </div>
              <h2 class="text-lg font-bold text-gray-900">Rovo-Readiness Assessment</h2>
            </div>
            <p class="text-base text-gray-600 leading-relaxed mb-5">
              Discover your organization's AI readiness tier with our 10-question assessment. Get a personalized action plan based on your score.
            </p>
            <a href="/rovo/assessment" class="btn-primary text-sm px-6 py-3 inline-block">
              <span class="relative z-10">Take the Assessment</span>
            </a>
          </div>
        )}

        <!-- ═══ Learning Path Card ═══ -->
        <div class="bg-white rounded-2xl p-6 lg:p-8 border border-gray-200 shadow-sm">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-xl bg-primary-50 flex items-center justify-center">
              <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" />
              </svg>
            </div>
            <h2 class="text-lg font-bold text-gray-900">Learning Path</h2>
          </div>

          {learningPath && pathName ? (
            <div>
              <p class="text-sm font-semibold text-primary-700 mb-3">{pathName}</p>

              <!-- Progress bar -->
              <div class="mb-4">
                <div class="flex items-center justify-between mb-1">
                  <span class="text-sm text-gray-600">{completedLessons} of {totalLessons} lessons</span>
                  <span class="text-sm font-medium text-gray-900">{pathProgress}%</span>
                </div>
                <div class="w-full bg-gray-100 rounded-full h-2.5">
                  <div class="h-2.5 rounded-full bg-primary-600 transition-all duration-500" style={`width: ${pathProgress}%`} />
                </div>
              </div>

              <!-- Lesson list -->
              {totalLessons > 0 && (
                <div class="space-y-2 mb-4">
                  {lessons.slice(0, 5).map((lesson) => {
                    const isNext = nextLesson && lesson.lessonId === nextLesson.lessonId;
                    const lessonDef = lesson.lessonId ? ALL_LESSONS[lesson.lessonId] : undefined;
                    const lessonTitle = lessonDef?.title ?? lesson.lessonId ?? 'Lesson';
                    const lessonSlug = lessonDef?.slug;
                    const href = lessonSlug ? `/member/lessons/${lessonSlug}` : '/member/lessons';
                    return (
                      <a href={href} class={`flex items-center gap-3 py-2 px-3 rounded-lg transition-colors hover:bg-gray-50 ${isNext ? 'bg-primary-50 border border-primary-200 hover:bg-primary-50' : ''}`}>
                        {lesson.status === 'completed' ? (
                          <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                          </svg>
                        ) : lesson.status === 'in_progress' ? (
                          <svg class="w-5 h-5 text-primary-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.91 11.672a.375.375 0 010 .656l-5.603 3.113a.375.375 0 01-.557-.328V8.887c0-.286.307-.466.557-.327l5.603 3.112z" />
                          </svg>
                        ) : (
                          <svg class="w-5 h-5 text-gray-300 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
                          </svg>
                        )}
                        <span class={`text-sm flex-1 ${lesson.status === 'completed' ? 'text-gray-500 line-through' : isNext ? 'text-primary-800 font-medium' : 'text-gray-700'}`}>
                          {lessonTitle}
                          {isNext && <span class="text-xs text-primary-600 ml-2">Up next</span>}
                        </span>
                      </a>
                    );
                  })}
                  {totalLessons > 5 && (
                    <p class="text-xs text-gray-400 pl-8">+ {totalLessons - 5} more lessons</p>
                  )}
                </div>
              )}
            </div>
          ) : latestAssessment ? (
            <div>
              <p class="text-base text-gray-600 leading-relaxed mb-4">
                Your learning path is being generated based on your assessment results. Check back soon.
              </p>
              <span class="inline-flex items-center text-sm font-medium text-gray-400">
                Coming soon
              </span>
            </div>
          ) : (
            <div>
              <p class="text-base text-gray-600 leading-relaxed mb-4">
                Complete the Rovo-Readiness Assessment to get a personalized learning path tailored to your weak dimensions.
              </p>
              <a href="/rovo/assessment" class="inline-flex items-center text-sm font-semibold text-primary-600 hover:text-primary-800 transition-colors">
                Take the assessment first
                <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </a>
            </div>
          )}
        </div>

        <!-- ═══ Membership Status Card ═══ -->
        <div class="bg-white rounded-2xl p-6 lg:p-8 border border-gray-200 shadow-sm">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-xl bg-primary-50 flex items-center justify-center">
              <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
              </svg>
            </div>
            <h2 class="text-lg font-bold text-gray-900">Membership</h2>
          </div>

          {membershipStatus === 'active' ? (
            <div>
              <div class="flex items-center gap-2 mb-4">
                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider bg-green-50 text-green-700 border border-green-200">
                  Active
                </span>
              </div>
              <p class="text-base text-gray-600 leading-relaxed mb-5">
                You have full access to the AI Readiness Lab, guided learning paths, and all member resources.
              </p>
              <button
                id="manage-subscription"
                class="inline-flex items-center text-sm font-semibold text-primary-600 hover:text-primary-800 transition-colors"
              >
                Manage subscription
                <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                </svg>
              </button>
            </div>
          ) : membershipStatus === 'cancelled' ? (
            <div>
              <div class="flex items-center gap-2 mb-4">
                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider bg-red-50 text-red-700 border border-red-200">
                  Cancelled
                </span>
              </div>
              <p class="text-base text-gray-600 leading-relaxed mb-5">
                Your membership has been cancelled. Reactivate to regain access to guided learning paths and Lab resources.
              </p>
              <button id="reactivate-membership" class="btn-primary text-sm px-6 py-3 inline-block">
                <span class="relative z-10">Reactivate membership</span>
              </button>
            </div>
          ) : membershipStatus === 'past_due' ? (
            <div>
              <div class="flex items-center gap-2 mb-4">
                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider bg-amber-50 text-amber-700 border border-amber-200">
                  Payment issue
                </span>
              </div>
              <p class="text-base text-gray-600 leading-relaxed mb-5">
                There's a problem with your payment. Please update your billing details to restore full access.
              </p>
              <button id="manage-subscription" class="btn-primary text-sm px-6 py-3 inline-block">
                <span class="relative z-10">Update billing</span>
              </button>
            </div>
          ) : membershipStatus === 'expired' ? (
            <div>
              <div class="flex items-center gap-2 mb-4">
                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider bg-red-50 text-red-700 border border-red-200">
                  Expired
                </span>
              </div>
              <p class="text-base text-gray-600 leading-relaxed mb-5">
                Your membership has expired. Renew to regain access to guided learning paths and Lab resources.
              </p>
              <button id="reactivate-membership" class="btn-primary text-sm px-6 py-3 inline-block">
                <span class="relative z-10">Renew membership</span>
              </button>
            </div>
          ) : (
            <div>
              <div class="flex items-center gap-2 mb-4">
                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider bg-gray-100 text-gray-600">
                  Free tier
                </span>
              </div>
              <p class="text-base text-gray-600 leading-relaxed mb-5">
