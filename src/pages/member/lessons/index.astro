---
import LandingLayout from '../../../layouts/LandingLayout.astro';
import { getEnvFromLocals } from '../../../lib/auth';
import { getDb, getMemberByAuthUserId, getMemberByEmail, getLearningPath, getLessonProgress } from '../../../lib/db/index';
import { LEARNING_PATHS } from '../../../lib/rovo/learning-paths';

export const prerender = false;

const user = (Astro.locals as Record<string, unknown>).user as {
  id: string;
  name: string;
  email: string;
} | undefined;

if (!user) {
  return Astro.redirect('/signin', 302);
}

// ─── Data loading ─────────────────────────────────────────────────────
type LessonProgressRow = {
  memberId: string | null;
  lessonId: string | null;
  status: string | null;
  startedAt: string | null;
  completedAt: string | null;
};

let membershipStatus = 'free';
let pathSlug: string | null = null;
let lessonProgressRows: LessonProgressRow[] = [];
let dbError = false;

try {
  const env = getEnvFromLocals(Astro.locals as Record<string, unknown>);
  if (env) {
    const db = getDb(env.DB);
    const member =
      (await getMemberByAuthUserId(db, user.id)) ??
      (await getMemberByEmail(db, user.email)) ??
      undefined;

    if (member) {
      membershipStatus = member.membershipStatus ?? 'free';
      const lp = await getLearningPath(db, member.id);
      pathSlug = lp?.pathSlug ?? null;
      lessonProgressRows = await getLessonProgress(db, member.id);
    }
  }
} catch (err) {
  console.error('[lessons/index] DB error:', err);
  dbError = true;
}

// ─── Derive path + progress ───────────────────────────────────────────
const pathDef = pathSlug ? LEARNING_PATHS[pathSlug] : null;

// Build a status map keyed by lessonId
const progressMap: Record<string, string> = {};
for (const row of lessonProgressRows) {
  if (row.lessonId && row.status) {
    progressMap[row.lessonId] = row.status;
  }
}

// Completed count across all lessons in path
const pathLessons = pathDef?.lessons ?? [];
const completedCount = pathLessons.filter((l) => progressMap[l.id] === 'completed').length;
const totalCount = pathLessons.length;
const pathProgress = totalCount > 0 ? Math.round((completedCount / totalCount) * 100) : 0;
---

<LandingLayout title="My Lessons" description="Your personalized learning path lessons." lightHeader={true} noIndex={true}>
  <section class="bg-gradient-to-b from-gray-50 to-white min-h-screen pt-28 pb-16 lg:pt-32 lg:pb-20 px-4">
    <div class="max-w-4xl mx-auto">

      <!-- Breadcrumb -->
      <nav class="mb-8 flex items-center gap-2 text-sm text-gray-500">
        <a href="/member/dashboard" class="hover:text-primary-600 transition-colors">Dashboard</a>
        <span>/</span>
        <span class="text-gray-900">My Lessons</span>
      </nav>

      <!-- Page header -->
      <div class="mb-10">
        <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900 tracking-tight" style="letter-spacing: -0.02em;">
          {pathDef ? pathDef.name : 'My Lessons'}
        </h1>
        {pathDef && (
          <p class="text-lg text-gray-600 mt-3 leading-relaxed max-w-3xl">
            {pathDef.description}
          </p>
        )}
      </div>

      {dbError ? (
        <!-- DB unavailable -->
        <div class="bg-amber-50 border border-amber-200 rounded-2xl p-6 text-center">
          <p class="text-base text-amber-800 font-medium">Could not load your lessons right now. Please try again in a moment.</p>
        </div>
      ) : !pathDef ? (
        <!-- No learning path assigned -->
        <div class="bg-white rounded-2xl border border-gray-200 p-8 lg:p-12 text-center">
          <div class="w-16 h-16 rounded-full bg-primary-50 flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" />
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-gray-900 mb-3">No learning path yet</h2>
          <p class="text-base text-gray-600 mb-6 max-w-lg mx-auto">
            Complete the Rovo-Readiness Assessment to get a personalized learning path tailored to your organization's gaps.
          </p>
          <a
            href="/rovo/assessment"
            class="inline-flex items-center justify-center px-6 py-3 rounded-xl bg-primary-600 text-white font-semibold text-base hover:bg-primary-700 transition-colors"
          >
            Take the Assessment
          </a>
        </div>
      ) : (
        <!-- Learning path with lessons -->
        <div>
          <!-- Progress summary -->
          <div class="bg-white rounded-2xl border border-gray-200 p-6 mb-6 flex flex-col sm:flex-row sm:items-center gap-4">
            <div class="flex-1">
              <div class="flex items-center justify-between mb-2">
                <span class="text-sm font-medium text-gray-700">{completedCount} of {totalCount} lessons completed</span>
                <span class="text-sm font-bold text-gray-900">{pathProgress}%</span>
              </div>
              <div class="w-full bg-gray-100 rounded-full h-2.5">
                <div class="h-2.5 rounded-full bg-primary-600 transition-all duration-500" style={`width: ${pathProgress}%`} />
              </div>
            </div>
          </div>

          <!-- Lesson list -->
          <div class="space-y-3">
            {pathLessons.map((lesson) => {
              const status = progressMap[lesson.id] ?? 'not_started';
              const isCompleted = status === 'completed';
              const isInProgress = status === 'in_progress';
              const isLocked = !lesson.is_free && membershipStatus !== 'active';

              return (
                <a
                  href={isLocked ? undefined : `/member/lessons/${lesson.slug}`}
                  class={`block bg-white rounded-2xl border p-5 lg:p-6 transition-all duration-150 ${
                    isLocked
                      ? 'border-gray-100 opacity-60 cursor-not-allowed'
                      : isCompleted
                        ? 'border-green-200 hover:border-green-300 hover:shadow-sm'
                        : isInProgress
                          ? 'border-primary-200 hover:border-primary-300 hover:shadow-sm'
                          : 'border-gray-200 hover:border-gray-300 hover:shadow-sm'
                  }`}
                >
                  <div class="flex items-start gap-4">
                    <!-- Status icon -->
                    <div class={`w-10 h-10 rounded-full flex-shrink-0 flex items-center justify-center ${
                      isCompleted
                        ? 'bg-green-100'
                        : isInProgress
                          ? 'bg-primary-50'
                          : isLocked
                            ? 'bg-gray-100'
                            : 'bg-gray-100'
                    }`}>
                      {isCompleted ? (
                        <svg class="w-5 h-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                        </svg>
                      ) : isInProgress ? (
                        <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                          <path stroke-linecap="round" stroke-linejoin="round" d="M15.91 11.672a.375.375 0 010 .656l-5.603 3.113a.375.375 0 01-.557-.328V8.887c0-.286.307-.466.557-.327l5.603 3.112z" />
                        </svg>
                      ) : isLocked ? (
                        <svg class="w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
                        </svg>
                      ) : (
                        <span class="text-sm font-bold text-gray-500">{lesson.order}</span>
                      )}
                    </div>

                    <!-- Content -->
                    <div class="flex-1 min-w-0">
                      <div class="flex flex-wrap items-center gap-2 mb-1">
                        <span class="text-sm text-gray-400">Lesson {lesson.order}</span>
                        {lesson.is_free && (
                          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-green-50 text-green-700">Free</span>
                        )}
                        {isCompleted && (
                          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-800">Completed</span>
                        )}
                        {isInProgress && !isCompleted && (
                          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-primary-50 text-primary-700">In Progress</span>
                        )}
                        {isLocked && (
                          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-500">Locked</span>
                        )}
                      </div>
                      <h3 class={`text-base font-bold mb-1 ${isCompleted ? 'text-gray-500' : 'text-gray-900'}`}>
                        {lesson.title}
                      </h3>
                      <p class="text-sm text-gray-500 leading-relaxed">
                        {lesson.description}
                      </p>
                      <p class="text-xs text-gray-400 mt-2">{lesson.duration_minutes} min</p>
                    </div>

                    <!-- Arrow -->
                    {!isLocked && (
                      <svg class="w-5 h-5 text-gray-300 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                      </svg>
                    )}
                  </div>
                </a>
              );
            })}
          </div>

          {membershipStatus !== 'active' && pathLessons.some((l) => !l.is_free) && (
            <div class="mt-8 bg-primary-50 border border-primary-200 rounded-2xl p-6 text-center">
              <p class="text-base font-semibold text-primary-800 mb-2">Unlock all lessons</p>
              <p class="text-sm text-primary-700 mb-4">Upgrade to the AI Readiness Lab to access every lesson in your path, plus live workshops and community access.</p>
              <a
                href="/pricing"
                class="inline-flex items-center justify-center px-6 py-3 rounded-xl bg-primary-600 text-white font-semibold text-sm hover:bg-primary-700 transition-colors"
              >
                Upgrade to Lab Membership
              </a>
            </div>
          )}
        </div>
      )}

    </div>
  </section>
</LandingLayout>
